{%- style -%}
  .footer {
    background: {{ settings.color_text }};
    color: {{ settings.color_background }};
    padding: 4rem 2rem 2rem;
  }

  .footer__container {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 3rem;
  }

  .footer__section h3 {
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
    color: {{ settings.color_primary }};
  }

  .footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer__links li {
    margin-bottom: 0.75rem;
  }

  .footer__links a {
    color: {{ settings.color_background }};
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }

  .footer__links a:hover {
    opacity: 1;
  }

  .footer__newsletter-form {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .footer__input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.1);
    color: {{ settings.color_background }};
    border-radius: 4px;
  }

  .footer__input::placeholder {
    color: rgba(255,255,255,0.6);
  }

  .footer__button {
    padding: 0.75rem 1.5rem;
    background: {{ settings.color_primary }};
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-weight: 600;
    transition: background 0.2s ease;
  }

  .footer__button:hover {
    background: {{ settings.color_secondary }};
  }

  .footer__bottom {
    max-width: 1400px;
    margin: 3rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.1);
    text-align: center;
    opacity: 0.6;
    font-size: 0.875rem;
  }

  .footer__social {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  .footer__social a {
    color: {{ settings.color_background }};
    opacity: 0.8;
  }

  .footer__social a:hover {
    opacity: 1;
  }
{%- endstyle -%}

<footer class="footer">
  <div class="footer__container">
    <div class="footer__section">
      <h3>{{ shop.name }}</h3>
      <p>{{ section.settings.footer_description }}</p>
    </div>

    <div class="footer__section">
      <h3>Quick Links</h3>
      <ul class="footer__links">
        {%- if section.settings.footer_menu != blank -%}
          {%- for link in linklists[section.settings.footer_menu].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        {%- else -%}
          <li><a href="{{ routes.root_url }}">Home</a></li>
          <li><a href="{{ routes.collections_url }}">Collections</a></li>
          <li><a href="{{ routes.products_url }}">Products</a></li>
          <li><a href="{{ routes.page_url }}">About</a></li>
          <li><a href="{{ routes.contact_url }}">Contact</a></li>
        {%- endif -%}
      </ul>
    </div>

    {%- if section.settings.show_newsletter -%}
      <div class="footer__section">
        <h3>Subscribe</h3>
        <p>Get exclusive offers and updates</p>
        {% form 'customer' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="footer__newsletter-form">
            <input 
              type="email" 
              name="contact[email]" 
              class="footer__input" 
              placeholder="Enter your email"
              required
            >
            <button type="submit" class="footer__button">Join</button>
          </div>
        {% endform %}
      </div>
    {%- endif -%}

    <div class="footer__section">
      <h3>Follow Us</h3>
      <div class="footer__social">
        {%- if section.settings.social_facebook != blank -%}
          <a href="{{ section.settings.social_facebook }}" target="_blank" rel="noopener">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_instagram != blank -%}
          <a href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_twitter != blank -%}
          <a href="{{ section.settings.social_twitter }}" target="_blank" rel="noopener">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="footer__bottom">
    <p>&copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All rights reserved.</p>
    <p>{{ section.settings.copyright_text }}</p>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "class": "footer-section",
  "settings": [
    {
      "type": "textarea",
      "id": "footer_description",
      "label": "Footer Description",
      "default": "Transform your health journey with our science-backed approach."
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer Menu"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show Newsletter Signup",
      "default": true
    },
    {
      "type": "text",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "text",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "text",
      "id": "social_twitter",
      "label": "Twitter URL"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "Results may vary. Consult your healthcare provider."
    }
  ]
}
{% endschema %}
