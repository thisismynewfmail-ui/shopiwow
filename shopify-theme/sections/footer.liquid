<footer class="footer" role="contentinfo">
  <style>
    .footer {
      background: #1A1A1A;
      color: white;
      padding: var(--spacing-xl) 0 var(--spacing-lg);
    }
    
    .footer__inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 var(--spacing-md);
    }
    
    .footer__grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: var(--spacing-xl);
      margin-bottom: var(--spacing-xl);
    }
    
    .footer__column h3 {
      font-size: 1.125rem;
      font-weight: 600;
      margin-bottom: var(--spacing-sm);
      color: white;
    }
    
    .footer__column p {
      color: #ccc;
      line-height: 1.8;
    }
    
    .footer__links {
      list-style: none;
    }
    
    .footer__links li {
      margin-bottom: var(--spacing-xs);
    }
    
    .footer__links a {
      color: #ccc;
      transition: color 0.2s ease;
    }
    
    .footer__links a:hover {
      color: white;
    }
    
    .footer__newsletter-form {
      display: flex;
      gap: var(--spacing-xs);
      margin-top: var(--spacing-sm);
    }
    
    .footer__input {
      flex: 1;
      padding: var(--spacing-sm);
      border: 1px solid #333;
      border-radius: var(--border-radius);
      background: #2a2a2a;
      color: white;
    }
    
    .footer__button {
      padding: var(--spacing-sm) var(--spacing-md);
      background: var(--color-primary);
      color: white;
      border: none;
      border-radius: var(--border-radius);
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s ease;
    }
    
    .footer__button:hover {
      background: var(--color-secondary);
    }
    
    .footer__bottom {
      border-top: 1px solid #333;
      padding-top: var(--spacing-lg);
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: var(--spacing-sm);
    }
    
    .footer__copyright {
      color: #999;
      font-size: 0.875rem;
    }
    
    .footer__social {
      display: flex;
      gap: var(--spacing-sm);
    }
    
    .footer__social a {
      color: #ccc;
      font-size: 1.25rem;
      transition: color 0.2s ease;
    }
    
    .footer__social a:hover {
      color: white;
    }
  </style>
  
  <div class="footer__inner">
    <div class="footer__grid">
      <div class="footer__column">
        <h3>{{ section.settings.brand_name | default: shop.name }}</h3>
        <p>{{ section.settings.footer_description | default: "Transform your health journey with our science-backed weight loss program." }}</p>
      </div>
      
      <div class="footer__column">
        <h3>Quick Links</h3>
        <ul class="footer__links">
          {% for link in section.settings.footer_menu.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
      
      <div class="footer__column">
        <h3>Contact</h3>
        <p>Email: {{ section.settings.contact_email | default: "support@example.com" }}</p>
        <p>Phone: {{ section.settings.contact_phone | default: "1-800-XXX-XXXX" }}</p>
      </div>
      
      {% if section.settings.enable_newsletter %}
      <div class="footer__column">
        <h3>Stay Updated</h3>
        <p>Subscribe to get special offers and health tips.</p>
        <form class="footer__newsletter-form" action="/contact#newsletter-form" method="post">
          <input type="email" name="contact[email]" class="footer__input" placeholder="Enter your email" required>
          <button type="submit" class="footer__button">Subscribe</button>
        </form>
      </div>
      {% endif %}
    </div>
    
    <div class="footer__bottom">
      <p class="footer__copyright">&copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All rights reserved.</p>
      <div class="footer__social">
        {% if section.settings.social_facebook != blank %}
          <a href="{{ section.settings.social_facebook }}" aria-label="Facebook">📘</a>
        {% endif %}
        {% if section.settings.social_instagram != blank %}
          <a href="{{ section.settings.social_instagram }}" aria-label="Instagram">📷</a>
        {% endif %}
        {% if section.settings.social_twitter != blank %}
          <a href="{{ section.settings.social_twitter }}" aria-label="Twitter">🐦</a>
        {% endif %}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand Name",
      "default": "Your Brand"
    },
    {
      "type": "textarea",
      "id": "footer_description",
      "label": "Footer Description",
      "default": "Transform your health journey with our science-backed weight loss program."
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer Menu",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Contact Email",
      "default": "support@example.com"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Contact Phone",
      "default": "1-800-XXX-XXXX"
    },
    {
      "type": "checkbox",
      "id": "enable_newsletter",
      "label": "Enable Newsletter Signup",
      "default": true
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "Twitter URL"
    }
  ]
}
{% endschema %}
