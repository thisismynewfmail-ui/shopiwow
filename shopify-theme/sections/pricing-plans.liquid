<section class="pricing-plans section">
  <style>
    .pricing-plans { background: var(--color-background); }
    .pricing-plans__inner { max-width: 1200px; margin: 0 auto; padding: 0 var(--spacing-md); }
    .pricing-plans__header { text-align: center; margin-bottom: var(--spacing-xl); }
    .pricing-plans__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--spacing-lg); max-width: 500px; margin: 0 auto; }
    .pricing-card { padding: var(--spacing-xl); border-radius: var(--border-radius); border: 2px solid var(--color-border); text-align: center; position: relative; transition: all 0.2s ease; }
    .pricing-card--featured { border-color: var(--color-primary); box-shadow: var(--shadow-lg); transform: scale(1.05); }
    .pricing-card__badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--color-primary); color: white; padding: var(--spacing-xs) var(--spacing-md); border-radius: 50px; font-size: 0.875rem; font-weight: 600; }
    .pricing-card__name { font-size: 1.5rem; font-weight: 700; margin-bottom: var(--spacing-sm); }
    .pricing-card__price { font-size: 3rem; font-weight: 800; color: var(--color-primary); margin-bottom: var(--spacing-xs); }
    .pricing-card__period { color: #666; margin-bottom: var(--spacing-lg); }
    .pricing-card__features { list-style: none; margin-bottom: var(--spacing-lg); text-align: left; }
    .pricing-card__features li { padding: var(--spacing-xs) 0; border-bottom: 1px solid var(--color-border); }
    .pricing-card__features li:last-child { border-bottom: none; }
    .pricing-card__features li::before { content: "✓"; color: var(--color-primary); font-weight: 700; margin-right: var(--spacing-xs); }
    .pricing-card__button { width: 100%; padding: var(--spacing-md); background: var(--color-primary); color: white; border: none; border-radius: var(--border-radius); font-weight: 600; font-size: 1rem; cursor: pointer; transition: background 0.2s ease; }
    .pricing-card__button:hover { background: #1B5E20; }
    .pricing-card__guarantee { margin-top: var(--spacing-sm); font-size: 0.875rem; color: #666; }
    @media (max-width: 768px) { .pricing-card--featured { transform: none; } }
  </style>
  <div class="pricing-plans__inner">
    <div class="pricing-plans__header">
      <span class="section-badge">{{ section.settings.pricing_badge }}</span>
      <h2 class="section-title">{{ section.settings.pricing_title }}</h2>
      <p class="section-subtitle">{{ section.settings.pricing_subtitle }}</p>
    </div>
    <div class="pricing-plans__grid">
      {% for block in section.blocks %}
        <div class="pricing-card {% if block.settings.featured %}pricing-card--featured{% endif %}" {{ block.shopify_attributes }}>
          {% if block.settings.badge_text != blank %}
            <span class="pricing-card__badge">{{ block.settings.badge_text }}</span>
          {% endif %}
          <h3 class="pricing-card__name">{{ block.settings.plan_name }}</h3>
          <div class="pricing-card__price">${{ block.settings.price }}</div>
          <div class="pricing-card__period">per {{ block.settings.period }}</div>
          <ul class="pricing-card__features">
            {% for feature in block.settings.features %}
              <li>{{ feature }}</li>
            {% endfor %}
          </ul>
          <button class="pricing-card__button">{{ block.settings.button_text }}</button>
          <p class="pricing-card__guarantee">{{ block.settings.guarantee_text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Pricing Plans",
  "settings": [
    {"type": "text", "id": "pricing_badge", "label": "Badge", "default": "Simple Pricing"},
    {"type": "text", "id": "pricing_title", "label": "Title", "default": "Choose Your Plan"},
    {"type": "textarea", "id": "pricing_subtitle", "label": "Subtitle", "default": "Start your transformation today."}
  ],
  "blocks": [
    {
      "type": "plan",
      "name": "Plan",
      "settings": [
        {"type": "text", "id": "badge_text", "label": "Badge Text", "default": "Most Popular"},
        {"type": "text", "id": "plan_name", "label": "Plan Name", "default": "Premium"},
        {"type": "text", "id": "price", "label": "Price", "default": "149"},
        {"type": "text", "id": "period", "label": "Period", "default": "month"},
        {"type": "checkbox", "id": "featured", "label": "Featured", "default": true},
        {"type": "textarea", "id": "features", "label": "Features (one per line)", "default": "Personalized meal plans\nDaily coaching support\nMobile app access"},
        {"type": "text", "id": "button_text", "label": "Button Text", "default": "Start Now"},
        {"type": "text", "id": "guarantee_text", "label": "Guarantee Text", "default": "30-day money-back guarantee"}
      ]
    }
  ],
  "presets": [{"name": "Pricing Plans", "blocks": [{"type": "plan"}]}]
}
{% endschema %}
