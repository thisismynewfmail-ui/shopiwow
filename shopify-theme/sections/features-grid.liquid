<section class="features-grid section">
  <style>
    .features-grid { background: var(--color-background); }
    .features-grid__inner { max-width: 1200px; margin: 0 auto; padding: 0 var(--spacing-md); }
    .features-grid__header { text-align: center; margin-bottom: var(--spacing-xl); }
    .features-grid__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: var(--spacing-lg); }
    .feature-card { padding: var(--spacing-lg); border-radius: var(--border-radius); background: var(--color-light-gray); text-align: center; transition: transform 0.2s ease; }
    .feature-card:hover { transform: translateY(-5px); }
    .feature-card__icon { font-size: 3rem; margin-bottom: var(--spacing-sm); }
    .feature-card__title { font-size: 1.25rem; font-weight: 600; margin-bottom: var(--spacing-xs); color: var(--color-text); }
    .feature-card__description { color: #666; line-height: 1.6; }
    @media (max-width: 768px) { .features-grid__grid { grid-template-columns: 1fr; } }
  </style>
  <div class="features-grid__inner">
    <div class="features-grid__header">
      <span class="section-badge">{{ section.settings.features_badge }}</span>
      <h2 class="section-title">{{ section.settings.features_title }}</h2>
      <p class="section-subtitle">{{ section.settings.features_subtitle }}</p>
    </div>
    <div class="features-grid__grid">
      {% for block in section.blocks %}
        <div class="feature-card" {{ block.shopify_attributes }}>
          <div class="feature-card__icon">{{ block.settings.icon }}</div>
          <h3 class="feature-card__title">{{ block.settings.title }}</h3>
          <p class="feature-card__description">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Features Grid",
  "settings": [
    {"type": "text", "id": "features_badge", "label": "Badge", "default": "Why Choose Us"},
    {"type": "text", "id": "features_title", "label": "Title", "default": "Everything You Need to Succeed"},
    {"type": "textarea", "id": "features_subtitle", "label": "Subtitle", "default": "Our comprehensive program gives you all the tools."}
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {"type": "text", "id": "icon", "label": "Icon Emoji", "default": "🎯"},
        {"type": "text", "id": "title", "label": "Title", "default": "Personalized Plan"},
        {"type": "textarea", "id": "description", "label": "Description", "default": "Custom-tailored approach for your needs."}
      ]
    }
  ],
  "presets": [{"name": "Features Grid", "blocks": [{"type": "feature"}, {"type": "feature"}, {"type": "feature"}, {"type": "feature"}]}]
}
{% endschema %}
