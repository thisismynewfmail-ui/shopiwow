{%- style -%}
  .countdown-bar {
    background: {{ settings.color_accent }};
    color: white;
    text-align: center;
    padding: 0.75rem 1rem;
    font-weight: 600;
    position: sticky;
    top: 0;
    z-index: 1001;
  }

  .countdown-bar__content {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .countdown-bar__timer {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .countdown-bar__unit {
    background: rgba(255,255,255,0.2);
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    min-width: 50px;
    text-align: center;
  }

  .countdown-bar__number {
    font-size: 1.25rem;
    font-weight: 800;
    display: block;
  }

  .countdown-bar__label {
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .countdown-bar__message {
    flex: 1;
    max-width: 600px;
  }

  @media screen and (max-width: 768px) {
    .countdown-bar__content {
      flex-direction: column;
      gap: 0.75rem;
    }

    .countdown-bar__timer {
      order: -1;
    }
  }
{%- endstyle -%}

{%- if section.settings.enable_countdown -%}
  <div class="countdown-bar" data-countdown-end="{{ section.settings.countdown_end_date }}">
    <div class="countdown-bar__content">
      <div class="countdown-bar__message">
        {{ section.settings.countdown_message }}
      </div>
      <div class="countdown-bar__timer">
        <div class="countdown-bar__unit">
          <span class="countdown-bar__number" data-hours>00</span>
          <span class="countdown-bar__label">Hours</span>
        </div>
        <div class="countdown-bar__unit">
          <span class="countdown-bar__number" data-minutes>00</span>
          <span class="countdown-bar__label">Minutes</span>
        </div>
        <div class="countdown-bar__unit">
          <span class="countdown-bar__number" data-seconds>00</span>
          <span class="countdown-bar__label">Seconds</span>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function() {
      const countdownEl = document.querySelector('.countdown-bar');
      if (!countdownEl) return;

      const endDate = new Date(countdownEl.dataset.countdownEnd).getTime();

      function updateCountdown() {
        const now = new Date().getTime();
        const distance = endDate - now;

        if (distance < 0) {
          // Reset countdown when it reaches zero
          const newEndDate = new Date();
          newEndDate.setHours(newEndDate.getHours() + {{ section.settings.countdown_hours }});
          localStorage.setItem('countdownEnd', newEndDate.getTime());
          location.reload();
          return;
        }

        const hours = Math.floor(distance / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        const hoursEl = countdownEl.querySelector('[data-hours]');
        const minutesEl = countdownEl.querySelector('[data-minutes]');
        const secondsEl = countdownEl.querySelector('[data-seconds]');

        if (hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
        if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, '0');
        if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, '0');
      }

      // Check for stored end date
      const storedEnd = localStorage.getItem('countdownEnd');
      if (storedEnd) {
        countdownEl.dataset.countdownEnd = storedEnd;
      } else {
        // Set initial end date
        const newEndDate = new Date();
        newEndDate.setHours(newEndDate.getHours() + {{ section.settings.countdown_hours }});
        localStorage.setItem('countdownEnd', newEndDate.getTime());
        countdownEl.dataset.countdownEnd = newEndDate;
      }

      updateCountdown();
      setInterval(updateCountdown, 1000);
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Countdown Bar",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_countdown",
      "label": "Enable Countdown",
      "default": true
    },
    {
      "type": "text",
      "id": "countdown_message",
      "label": "Countdown Message",
      "default": "⚡ Special Offer Ends Soon! Lock in your spot before prices increase!"
    },
    {
      "type": "range",
      "id": "countdown_hours",
      "min": 1,
      "max": 24,
      "step": 1,
      "default": 4,
      "label": "Countdown Duration (hours)",
      "info": "Timer will reset after reaching zero"
    },
    {
      "type": "date",
      "id": "countdown_end_date",
      "label": "End Date (optional)",
      "info": "Leave empty to use duration-based countdown"
    }
  ],
  "presets": [
    {
      "name": "Countdown Bar"
    }
  ]
}
{% endschema %}
