<div class="countdown-bar" {% if section.settings.enable_countdown == false %}style="display:none;"{% endif %}>
  <style>
    .countdown-bar { background: var(--color-accent); color: white; padding: var(--spacing-sm) var(--spacing-md); text-align: center; font-weight: 600; }
    .countdown-bar__timer { display: inline-block; margin-left: var(--spacing-sm); font-family: monospace; font-size: 1.125rem; }
  </style>
  <div class="container">
    <span>{{ section.settings.countdown_message }}</span>
    <span class="countdown-bar__timer" id="countdown-timer"></span>
  </div>
  <script>
    (function() {
      var hours = {{ section.settings.countdown_hours | default: 4 }};
      var endTime = Date.now() + (hours * 60 * 60 * 1000);
      function updateTimer() {
        var now = Date.now();
        var diff = Math.max(0, endTime - now);
        var h = Math.floor(diff / (1000 * 60 * 60));
        var m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        var s = Math.floor((diff % (1000 * 60)) / 1000);
        document.getElementById('countdown-timer').textContent = h + ':' + String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
        if (diff <= 0) document.querySelector('.countdown-bar').style.display = 'none';
      }
      setInterval(updateTimer, 1000);
      updateTimer();
    })();
  </script>
</div>
{% schema %}
{
  "name": "Countdown Bar",
  "settings": [
    {"type": "checkbox", "id": "enable_countdown", "label": "Enable Countdown", "default": true},
    {"type": "text", "id": "countdown_message", "label": "Message", "default": "⚡ Special Offer Ends Soon!"},
    {"type": "range", "id": "countdown_hours", "label": "Hours", "min": 1, "max": 24, "step": 1, "default": 4}
  ]
}
{% endschema %}
