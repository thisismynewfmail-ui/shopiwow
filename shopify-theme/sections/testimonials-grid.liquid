<section class="testimonials-grid section">
  <style>
    .testimonials-grid { background: var(--color-light-gray); }
    .testimonials-grid__inner { max-width: 1200px; margin: 0 auto; padding: 0 var(--spacing-md); }
    .testimonials-grid__header { text-align: center; margin-bottom: var(--spacing-xl); }
    .testimonials-grid__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--spacing-lg); }
    .testimonial-card { padding: var(--spacing-lg); border-radius: var(--border-radius); background: white; box-shadow: var(--shadow-sm); }
    .testimonial-card__text { font-size: 1.125rem; line-height: 1.8; color: var(--color-text); margin-bottom: var(--spacing-md); font-style: italic; }
    .testimonial-card__author { display: flex; align-items: center; gap: var(--spacing-sm); }
    .testimonial-card__avatar { width: 50px; height: 50px; border-radius: 50%; background: var(--color-primary); display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; }
    .testimonial-card__info h4 { font-weight: 600; margin: 0; }
    .testimonial-card__location { color: #666; font-size: 0.875rem; }
    .testimonial-card__result { margin-top: var(--spacing-sm); padding-top: var(--spacing-sm); border-top: 1px solid var(--color-border); color: var(--color-primary); font-weight: 600; }
    @media (max-width: 768px) { .testimonials-grid__grid { grid-template-columns: 1fr; } }
  </style>
  <div class="testimonials-grid__inner">
    <div class="testimonials-grid__header">
      <span class="section-badge">{{ section.settings.testimonials_badge }}</span>
      <h2 class="section-title">{{ section.settings.testimonials_title }}</h2>
      <p class="section-subtitle">{{ section.settings.testimonials_subtitle }}</p>
    </div>
    <div class="testimonials-grid__grid">
      {% for block in section.blocks %}
        <div class="testimonial-card" {{ block.shopify_attributes }}>
          <p class="testimonial-card__text">"{{ block.settings.testimonial_text }}"</p>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar">{{ block.settings.author_name | slice: 0 }}</div>
            <div class="testimonial-card__info">
              <h4>{{ block.settings.author_name }}</h4>
              <span class="testimonial-card__location">{{ block.settings.author_location }}</span>
            </div>
          </div>
          <div class="testimonial-card__result">{{ block.settings.result_text }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Testimonials Grid",
  "settings": [
    {"type": "text", "id": "testimonials_badge", "label": "Badge", "default": "Success Stories"},
    {"type": "text", "id": "testimonials_title", "label": "Title", "default": "Real People, Real Results"},
    {"type": "textarea", "id": "testimonials_subtitle", "label": "Subtitle", "default": "See how our program has transformed lives."}
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {"type": "textarea", "id": "testimonial_text", "label": "Testimonial Text", "default": "This program changed my life!"},
        {"type": "text", "id": "author_name", "label": "Author Name", "default": "Sarah M."},
        {"type": "text", "id": "author_location", "label": "Location", "default": "Texas"},
        {"type": "text", "id": "result_text", "label": "Result Text", "default": "Lost 35 lbs in 3 months"}
      ]
    }
  ],
  "presets": [{"name": "Testimonials Grid", "blocks": [{"type": "testimonial"}, {"type": "testimonial"}, {"type": "testimonial"}]}]
}
{% endschema %}
