<div class="social-proof-notification" id="social-proof" style="display:none;">
  <style>
    .social-proof-notification { position: fixed; bottom: 20px; left: 20px; background: white; padding: var(--spacing-md); border-radius: var(--border-radius); box-shadow: var(--shadow-lg); z-index: 9999; max-width: 300px; animation: slideIn 0.5s ease; }
    @keyframes slideIn { from { transform: translateX(-100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
    .social-proof-notification__icon { font-size: 1.5rem; margin-right: var(--spacing-sm); }
    .social-proof-notification__content { display: flex; align-items: center; gap: var(--spacing-sm); }
    .social-proof-notification__text { font-size: 0.875rem; color: var(--color-text); }
    .social-proof-notification__time { font-size: 0.75rem; color: #999; margin-top: 4px; }
  </style>
  <div class="social-proof-notification__content">
    <span class="social-proof-notification__icon">🎉</span>
    <div>
      <p class="social-proof-notification__text"><strong id="sp-name">Sarah M.</strong> from <span id="sp-location">Texas</span> just subscribed!</p>
      <p class="social-proof-notification__time" id="sp-time">2 minutes ago</p>
    </div>
  </div>
  <script>
    (function() {
      var names = ['Sarah M.', 'Jessica T.', 'Amanda R.', 'Emily K.', 'Michelle D.'];
      var locations = ['Texas', 'California', 'Florida', 'New York', 'Ohio'];
      var times = ['1 minute ago', '3 minutes ago', '5 minutes ago', '8 minutes ago'];
      function showNotification() {
        var name = names[Math.floor(Math.random() * names.length)];
        var location = locations[Math.floor(Math.random() * locations.length)];
        var time = times[Math.floor(Math.random() * times.length)];
        document.getElementById('sp-name').textContent = name;
        document.getElementById('sp-location').textContent = location;
        document.getElementById('sp-time').textContent = time;
        document.getElementById('social-proof').style.display = 'block';
        setTimeout(function() { document.getElementById('social-proof').style.display = 'none'; }, 5000);
      }
      setInterval(showNotification, 15000);
      setTimeout(showNotification, 3000);
    })();
  </script>
</div>
{% schema %}
{
  "name": "Social Proof Notification",
  "settings": []
}
{% endschema %}
