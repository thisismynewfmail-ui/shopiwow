{%- style -%}
  .header-wrapper {
    background: {{ settings.color_background }};
    border-bottom: 1px solid #e5e5e5;
    position: {% if section.settings.sticky_header %}sticky{% else %}relative{% endif %};
    top: 0;
    z-index: 1000;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .header__logo {
    flex-shrink: 0;
  }

  .header__logo img {
    max-width: {{ section.settings.logo_width }}px;
    height: auto;
  }

  .header__nav {
    display: flex;
    gap: 2rem;
  }

  .header__nav a {
    color: {{ settings.color_text }};
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .header__nav a:hover {
    color: {{ settings.color_primary }};
  }

  .header__icons {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .header__cart {
    position: relative;
    color: {{ settings.color_text }};
  }

  @media screen and (max-width: 768px) {
    .header {
      flex-direction: column;
      gap: 1rem;
      padding: 1rem;
    }

    .header__nav {
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: center;
    }
  }
{%- endstyle -%}

<header class="header-wrapper">
  <div class="header">
    <div class="header__logo">
      {%- if section.settings.logo != blank -%}
        <a href="{{ routes.root_url }}">
          <img src="{{ section.settings.logo | image_url: width: 600 }}" alt="{{ shop.name }}" loading="eager">
        </a>
      {%- else -%}
        <a href="{{ routes.root_url }}" class="h2">{{ shop.name }}</a>
      {%- endif -%}
    </div>

    <nav class="header__nav" role="navigation">
      {%- if section.settings.menu != blank -%}
        {%- for link in linklists[section.settings.menu].links -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
      {%- endif -%}
    </nav>

    <div class="header__icons">
      {%- if section.settings.show_cart_icon -%}
        <a href="{{ routes.cart_url }}" class="header__cart">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="21" r="1"></circle>
            <circle cx="20" cy="21" r="1"></circle>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
          </svg>
          <span class="visually-hidden">Cart</span>
        </a>
      {%- endif -%}
    </div>
  </div>
</header>

{% schema %}
{
  "type": "header",
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 10,
      "default": 150,
      "label": "Logo Width (px)",
      "unit": "px"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "show_cart_icon",
      "label": "Show Cart Icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Sticky Header",
      "default": true
    }
  ]
}
{% endschema %}
