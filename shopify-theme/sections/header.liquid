<header class="header" role="banner">
  <style>
    .header {
      background: var(--color-background);
      box-shadow: var(--shadow-sm);
      position: sticky;
      top: 0;
      z-index: 1000;
    }
    
    .header__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: var(--spacing-sm) var(--spacing-md);
      max-width: 1200px;
      margin: 0 auto;
    }
    
    .header__logo {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--color-primary);
    }
    
    .header__nav {
      display: flex;
      gap: var(--spacing-lg);
    }
    
    .header__nav a {
      font-weight: 500;
      color: var(--color-text);
      transition: color 0.2s ease;
    }
    
    .header__nav a:hover {
      color: var(--color-primary);
    }
    
    .header__cart {
      display: flex;
      align-items: center;
      gap: var(--spacing-xs);
      color: var(--color-text);
    }
    
    .header__cart-icon {
      width: 24px;
      height: 24px;
    }
    
    .header__mobile-toggle {
      display: none;
      background: none;
      border: none;
      font-size: 1.5rem;
      cursor: pointer;
    }
    
    @media (max-width: 768px) {
      .header__nav {
        display: none;
      }
      
      .header__mobile-toggle {
        display: block;
      }
    }
  </style>
  
  <div class="header__inner">
    <a href="{{ routes.root_url }}" class="header__logo">
      {{ section.settings.logo_text | default: shop.name }}
    </a>
    
    <nav class="header__nav" role="navigation">
      {% for link in section.settings.menu.links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
    </nav>
    
    <div class="header__cart">
      <a href="{{ routes.cart_url }}" class="header__cart-link">
        <svg class="header__cart-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        <span class="header__cart-count">{{ cart.item_count }}</span>
      </a>
      <button class="header__mobile-toggle" aria-label="Toggle menu">☰</button>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "Your Brand"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
