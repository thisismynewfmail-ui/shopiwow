{%- style -%}
  .blog {
    padding: 4rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .blog__title {
    font-size: 2.5rem;
    text-align: center;
    margin-bottom: 3rem;
  }

  .blog__list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .blog__article {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  }

  .blog__article img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
  }

  .blog__article-body {
    padding: 1.5rem;
  }

  .blog__article-title {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .blog__article-title a {
    color: {{ settings.color_text }};
    text-decoration: none;
  }

  .blog__article-meta {
    color: #777;
    font-size: 0.875rem;
    margin-bottom: 0.75rem;
  }

  .blog__article-excerpt {
    color: #555;
    font-size: 0.9375rem;
    line-height: 1.6;
  }
{%- endstyle -%}

<div class="blog">
  <h1 class="blog__title">{{ blog.title }}</h1>

  {%- paginate blog.articles by 12 -%}
    <div class="blog__list">
      {%- for article in blog.articles -%}
        <article class="blog__article">
          {%- if article.image != blank -%}
            <a href="{{ article.url }}">
              <img src="{{ article.image | image_url: width: 800 }}" alt="{{ article.image.alt | escape }}" loading="lazy">
            </a>
          {%- endif -%}
          <div class="blog__article-body">
            <h2 class="blog__article-title"><a href="{{ article.url }}">{{ article.title }}</a></h2>
            <p class="blog__article-meta">{{ article.published_at | date: format: 'month_day_year' }}</p>
            <p class="blog__article-excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 30 }}</p>
          </div>
        </article>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav class="pagination">{{ paginate | default_pagination }}</nav>
    {%- endif -%}
  {%- endpaginate -%}
</div>
