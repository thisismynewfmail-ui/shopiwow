{%- style -%}
  .password {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, {{ settings.color_primary }} 0%, {{ settings.color_secondary }} 100%);
    padding: 2rem;
    text-align: center;
    color: white;
  }

  .password__inner {
    max-width: 500px;
  }

  .password__logo {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .password__title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .password__text {
    font-size: 1.125rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .password__form {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .password__input {
    padding: 0.875rem 1rem;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    min-width: 220px;
  }

  .password__button {
    padding: 0.875rem 1.75rem;
    border: none;
    border-radius: 8px;
    background: {{ settings.color_accent }};
    color: white;
    font-weight: 700;
    cursor: pointer;
  }
{%- endstyle -%}

<div class="password">
  <div class="password__inner">
    <div class="password__logo">{{ shop.name }}</div>
    <h1 class="password__title">{{ 'general.password_page.opening_soon' | t }}</h1>
    <p class="password__text">
      {%- if shop.password_message != blank -%}
        {{ shop.password_message }}
      {%- else -%}
        Enter your password to access the store.
      {%- endif -%}
    </p>

    {%- form 'storefront_password' -%}
      {%- if form.errors -%}
        <p style="color:#ffecec;">{{ form.errors | default_errors }}</p>
      {%- endif -%}
      <div class="password__form">
        <input type="password" name="password" class="password__input" placeholder="Password" required>
        <button type="submit" class="password__button">Enter</button>
      </div>
    {%- endform -%}
  </div>
</div>
