{%- style -%}
  .page {
    padding: 4rem 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .page__title {
    font-size: 2.5rem;
    margin-bottom: 2rem;
    color: {{ settings.color_text }};
  }

  .page__content {
    line-height: 1.7;
    color: {{ settings.color_text }};
  }

  .page__content p {
    margin-bottom: 1rem;
  }
{%- endstyle -%}

<div class="page">
  <h1 class="page__title">{{ page.title }}</h1>
  <div class="page__content rte">
    {{ page.content }}
  </div>
</div>
