{%- style -%}
  .error-404 {
    padding: 6rem 2rem;
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .error-404__title {
    font-size: 3rem;
    margin-bottom: 1rem;
    color: {{ settings.color_primary }};
  }

  .error-404__text {
    font-size: 1.125rem;
    color: #666;
    margin-bottom: 2rem;
  }

  .error-404__link {
    display: inline-block;
    padding: 1rem 2rem;
    background: {{ settings.color_primary }};
    color: white;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 600;
  }
{%- endstyle -%}

<div class="error-404">
  <h1 class="error-404__title">{{ 'general.404.title' | t }}</h1>
  <p class="error-404__text">{{ 'general.404.subtext' | t }}</p>
  <a class="error-404__link" href="{{ routes.root_url }}">&larr; {{ shop.name }}</a>
</div>
