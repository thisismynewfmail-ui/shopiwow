{%- style -%}
  .search {
    padding: 4rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .search__title {
    font-size: 2.25rem;
    text-align: center;
    margin-bottom: 2rem;
  }

  .search__form {
    display: flex;
    gap: 0.5rem;
    max-width: 600px;
    margin: 0 auto 3rem;
  }

  .search__input {
    flex: 1;
    padding: 0.875rem 1rem;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-size: 1rem;
  }

  .search__button {
    padding: 0.875rem 1.75rem;
    background: {{ settings.color_primary }};
    color: white;
    border: none;
    border-radius: 8px;
    font-weight: 700;
    cursor: pointer;
  }

  .search__results {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .search__result {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    padding: 1rem 1.25rem 1.25rem;
  }

  .search__result h3 {
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }

  .search__result a {
    color: {{ settings.color_text }};
    text-decoration: none;
  }
{%- endstyle -%}

<div class="search">
  <h1 class="search__title">Search</h1>

  <form action="{{ routes.search_url }}" method="get" class="search__form" role="search">
    <input
      type="search"
      name="q"
      value="{{ search.terms | escape }}"
      placeholder="Search..."
      class="search__input"
      aria-label="Search"
    >
    <button type="submit" class="search__button">Search</button>
  </form>

  {%- if search.performed -%}
    {%- if search.results_count > 0 -%}
      <p>{{ search.results_count }} results for &ldquo;{{ search.terms | escape }}&rdquo;</p>
      <div class="search__results">
        {%- for item in search.results -%}
          <div class="search__result">
            <h3><a href="{{ item.url }}">{{ item.title }}</a></h3>
            {%- if item.object_type == 'product' -%}
              <p>{{ item.price | money }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p>No results for &ldquo;{{ search.terms | escape }}&rdquo;.</p>
    {%- endif -%}
  {%- endif -%}
</div>
