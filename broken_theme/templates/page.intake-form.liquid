<div class="medvi-intake">
  <div class="medvi-intake__container">
    <div class="medvi-intake__header">
      <h1 class="medvi-intake__title">Get Started with MEDVi</h1>
      <p class="medvi-intake__subtitle">Complete our quick online evaluation to see if you qualify for GLP-1 medication.</p>
    </div>
    
    <div class="medvi-intake__form">
      <div class="medvi-intake__step">
        <h2>Step 1: Your Information</h2>
        <div class="medvi-intake__field">
          <label for="full-name">Full Name</label>
          <input type="text" id="full-name" name="full_name" placeholder="Enter your full name">
        </div>
        <div class="medvi-intake__field">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" placeholder="Enter your email">
        </div>
        <div class="medvi-intake__field">
          <label for="phone">Phone Number</label>
          <input type="tel" id="phone" name="phone" placeholder="Enter your phone number">
        </div>
      </div>
      
      <div class="medvi-intake__step">
        <h2>Step 2: Health Information</h2>
        <div class="medvi-intake__field">
          <label for="age">Age</label>
          <input type="number" id="age" name="age" placeholder="Enter your age" min="18" max="100">
        </div>
        <div class="medvi-intake__field">
          <label for="weight">Current Weight (lbs)</label>
          <input type="number" id="weight" name="weight" placeholder="Enter your weight" min="80" max="500">
        </div>
        <div class="medvi-intake__field">
          <label for="height">Height (inches)</label>
          <input type="number" id="height" name="height" placeholder="Enter your height in inches" min="48" max="108">
        </div>
      </div>
      
      <div class="medvi-intake__step">
        <h2>Step 3: Medical History</h2>
        <div class="medvi-intake__field">
          <label for="conditions">Do you have any of the following conditions?</label>
          <select id="conditions" name="conditions">
            <option value="">Select a condition</option>
            <option value="diabetes">Type 2 Diabetes</option>
            <option value="heart-disease">Heart Disease</option>
            <option value="high-blood-pressure">High Blood Pressure</option>
            <option value="thyroid">Thyroid Condition</option>
            <option value="none">None of the above</option>
          </select>
        </div>
        <div class="medvi-intake__field">
          <label for="medications">Current Medications</label>
          <textarea id="medications" name="medications" placeholder="List any current medications"></textarea>
        </div>
      </div>
      
      <button type="submit" class="medvi-intake__submit">Submit & Get Approved</button>
    </div>
    
    <div class="medvi-intake__info">
      <div class="medvi-intake__info-item">
        <img src="{{ 'icn-doctor.svg' | asset_url }}" alt="Doctor">
        <span>Licensed Medical Providers</span>
      </div>
      <div class="medvi-intake__info-item">
        <img src="{{ 'icn-guarantee.svg' | asset_url }}" alt="Guarantee">
        <span>MEDVi Guarantee</span>
      </div>
      <div class="medvi-intake__info-item">
        <img src="{{ 'icn-shipping.svg' | asset_url }}" alt="Shipping">
        <span>Free Shipping</span>
      </div>
    </div>
  </div>
</div>

<style>
  .medvi-intake {
    padding: 100px 0 60px;
    background: #f8f6f5;
    min-height: 100vh;
  }
  
  .medvi-intake__container {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  
  .medvi-intake__header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .medvi-intake__title {
    font-size: 2.5rem;
    font-weight: 800;
    color: #121231;
    margin-bottom: 1rem;
  }
  
  .medvi-intake__subtitle {
    font-size: 1.1rem;
    color: #666;
  }
  
  .medvi-intake__form {
    background: #fff;
    padding: 2rem;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  }
  
  .medvi-intake__step {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #e4dcd8;
  }
  
  .medvi-intake__step:last-of-type {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
  }
  
  .medvi-intake__step h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #121231;
    margin-bottom: 1.5rem;
  }
  
  .medvi-intake__field {
    margin-bottom: 1.5rem;
  }
  
  .medvi-intake__field:last-child {
    margin-bottom: 0;
  }
  
  .medvi-intake__field label {
    display: block;
    font-weight: 600;
    color: #121231;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
  }
  
  .medvi-intake__field input,
  .medvi-intake__field select,
  .medvi-intake__field textarea {
    width: 100%;
    padding: 0.875rem 1rem;
    border: 2px solid #e4dcd8;
    border-radius: 8px;
    font-size: 1rem;
    font-family: inherit;
    transition: border-color 0.3s ease;
    box-sizing: border-box;
  }
  
  .medvi-intake__field input:focus,
  .medvi-intake__field select:focus,
  .medvi-intake__field textarea:focus {
    outline: none;
    border-color: #08a88a;
  }
  
  .medvi-intake__field textarea {
    min-height: 100px;
    resize: vertical;
  }
  
  .medvi-intake__submit {
    width: 100%;
    padding: 1rem 2rem;
    background: #08a88a;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 1rem;
  }
  
  .medvi-intake__submit:hover {
    background: #069b7a;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(8, 168, 138, 0.3);
  }
  
  .medvi-intake__info {
    display: flex;
    justify-content: center;
    gap: 3rem;
    margin-top: 3rem;
    flex-wrap: wrap;
  }
  
  .medvi-intake__info-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #666;
  }
  
  .medvi-intake__info-item img {
    width: 24px;
    height: 24px;
  }
</style>

{% schema %}
{
  "name": "Intake Form Page",
  "settings": []
}
{% endschema %}