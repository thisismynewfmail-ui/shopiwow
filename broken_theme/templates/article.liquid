{%- style -%}
  .article {
    padding: 4rem 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .article__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .article__title {
    font-size: 2.5rem;
    color: {{ settings.color_text }};
    margin-bottom: 1rem;
  }

  .article__meta {
    color: #777;
    font-size: 0.875rem;
  }

  .article__image {
    margin-bottom: 2rem;
  }

  .article__content {
    line-height: 1.8;
    font-size: 1.0625rem;
  }

  .article__content p {
    margin-bottom: 1.25rem;
  }
{%- endstyle -%}

<article class="article">
  <header class="article__header">
    <h1 class="article__title">{{ article.title }}</h1>
    <p class="article__meta">
      {{ article.published_at | date: format: 'month_day_year' }}
      {%- if article.author != blank %} &middot; {{ article.author }}{%- endif -%}
    </p>
  </header>

  {%- if article.image != blank -%}
    <div class="article__image">
      <img src="{{ article.image | image_url: width: 1200 }}" alt="{{ article.image.alt | escape }}" loading="lazy">
    </div>
  {%- endif -%}

  <div class="article__content rte">
    {{ article.content }}
  </div>

  {%- if blog.comments_enabled? -%}
    <section class="article__comments">
      <h2>Comments ({{ article.comments_count }})</h2>

      {%- if article.comments_count > 0 -%}
        {%- for comment in article.comments -%}
          <div class="comment">
            <p><strong>{{ comment.author }}</strong> &middot; {{ comment.created_at | date: format: 'month_day_year' }}</p>
            <div>{{ comment.content }}</div>
          </div>
        {%- endfor -%}
      {%- endif -%}

      {%- form 'new_comment', article -%}
        <label for="CommentAuthor">Name</label>
        <input type="text" name="comment[author]" id="CommentAuthor" required>

        <label for="CommentEmail">Email</label>
        <input type="email" name="comment[email]" id="CommentEmail" required>

        <label for="CommentBody">Comment</label>
        <textarea name="comment[body]" id="CommentBody" required></textarea>

        <button type="submit">Post comment</button>
      {%- endform -%}
    </section>
  {%- endif -%}
</article>
