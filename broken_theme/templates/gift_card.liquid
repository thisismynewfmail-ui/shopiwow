<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_primary }}">
    <title>{{ 'gift_cards.issued.title' | t }}</title>

    {% render 'css-variables' %}

    <style>
      body {
        background: {{ settings.color_background }};
        color: {{ settings.color_text }};
      }

      .gift-card {
        max-width: 560px;
        margin: 4rem auto;
        padding: 2.5rem;
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.08);
        text-align: center;
      }

      .gift-card__logo {
        font-size: 1.5rem;
        font-weight: 800;
        color: {{ settings.color_primary }};
        margin-bottom: 1rem;
      }

      .gift-card__title {
        font-size: 1.5rem;
        margin-bottom: 2rem;
      }

      .gift-card__amount {
        font-size: 3rem;
        font-weight: 800;
        color: {{ settings.color_primary }};
        margin-bottom: 1rem;
      }

      .gift-card__image {
        max-width: 100%;
        margin-bottom: 1.5rem;
      }

      .gift-card__code {
        display: inline-block;
        padding: 1rem 1.5rem;
        background: #f7f7f7;
        border-radius: 8px;
        font-family: monospace;
        font-size: 1.125rem;
        letter-spacing: 2px;
        margin: 1rem 0;
      }

      .gift-card__actions {
        margin-top: 2rem;
      }

      .gift-card__actions a {
        display: inline-block;
        padding: 0.875rem 1.5rem;
        background: {{ settings.color_primary }};
        color: white;
        text-decoration: none;
        border-radius: 8px;
        font-weight: 700;
        margin: 0.25rem;
      }
    </style>
  </head>
  <body>
    <div class="gift-card">
      <div class="gift-card__logo">{{ shop.name }}</div>
      <h1 class="gift-card__title">{{ 'gift_cards.issued.subtext' | t }}</h1>

      <p class="gift-card__amount">{{ gift_card.initial_value | money }}</p>

      {%- if gift_card.image != blank -%}
        <img class="gift-card__image" src="{{ gift_card.image | image_url: width: 500 }}" alt="Gift card">
      {%- endif -%}

      <p>{{ 'gift_cards.issued.redeem_html' | t: value: gift_card.balance | money }}</p>

      <div class="gift-card__code">{{ gift_card.code | format_code }}</div>

      <div class="gift-card__actions">
        <a href="{{ shop.url }}">{{ 'gift_cards.issued.shop_link' | t }}</a>
        <a href="#" onclick="window.print();return false;">{{ 'gift_cards.issued.print' | t }}</a>
      </div>
    </div>
  </body>
</html>
