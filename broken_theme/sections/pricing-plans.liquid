{%- style -%}
  .pricing {
    padding: 5rem 2rem;
    background: {{ settings.color_background }};
  }

  .pricing__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .pricing__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .pricing__badge {
    display: inline-block;
    background: {{ settings.color_accent }};
    color: white;
    padding: 0.5rem 1.5rem;
    border-radius: 50px;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .pricing__title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: {{ settings.color_text }};
    margin-bottom: 1rem;
  }

  .pricing__subtitle {
    font-size: 1.125rem;
    color: #666;
    max-width: 600px;
    margin: 0 auto;
  }

  .pricing__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    align-items: stretch;
  }

  .pricing-card {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .pricing-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.15);
  }

  .pricing-card--featured {
    border: 3px solid {{ settings.color_primary }};
    transform: scale(1.05);
  }

  .pricing-card--featured:hover {
    transform: scale(1.05) translateY(-10px);
  }

  .pricing-card__badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: {{ settings.color_accent }};
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .pricing-card__header {
    padding: 2.5rem 2rem 2rem;
    text-align: center;
    border-bottom: 1px solid #f0f0f0;
  }

  .pricing-card__plan-name {
    font-size: 1.25rem;
    font-weight: 600;
    color: #666;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .pricing-card__price {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.25rem;
  }

  .pricing-card__currency {
    font-size: 1.5rem;
    color: {{ settings.color_text }};
  }

  .pricing-card__amount {
    font-size: 4rem;
    font-weight: 800;
    color: {{ settings.color_primary }};
    line-height: 1;
  }

  .pricing-card__period {
    font-size: 1rem;
    color: #999;
  }

  .pricing-card__body {
    padding: 2rem;
    flex: 1;
  }

  .pricing-card__features {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .pricing-card__feature {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid #f5f5f5;
    font-size: 0.9375rem;
    color: {{ settings.color_text }};
  }

  .pricing-card__feature:last-child {
    border-bottom: none;
  }

  .pricing-card__feature-icon {
    color: {{ settings.color_primary }};
    flex-shrink: 0;
  }

  .pricing-card__footer {
    padding: 2rem;
    border-top: 1px solid #f0f0f0;
  }

  .pricing-card__button {
    display: block;
    width: 100%;
    padding: 1.25rem 2rem;
    background: {{ settings.color_primary }};
    color: white;
    text-align: center;
    text-decoration: none;
    font-size: 1.125rem;
    font-weight: 700;
    border-radius: 12px;
    transition: background 0.2s ease, transform 0.2s ease;
    border: none;
    cursor: pointer;
  }

  .pricing-card__button:hover {
    background: {{ settings.color_secondary }};
    transform: translateY(-2px);
  }

  .pricing-card__guarantee {
    text-align: center;
    margin-top: 1rem;
    font-size: 0.8125rem;
    color: #999;
  }

  @media screen and (max-width: 992px) {
    .pricing-card--featured {
      transform: none;
    }

    .pricing-card--featured:hover {
      transform: translateY(-10px);
    }
  }

  @media screen and (max-width: 768px) {
    .pricing {
      padding: 3rem 1rem;
    }

    .pricing__grid {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

<section class="pricing">
  <div class="pricing__container">
    <div class="pricing__header">
      {%- if section.settings.pricing_badge != blank -%}
        <span class="pricing__badge">{{ section.settings.pricing_badge }}</span>
      {%- endif -%}

      <h2 class="pricing__title">{{ section.settings.pricing_title }}</h2>

      {%- if section.settings.pricing_subtitle != blank -%}
        <p class="pricing__subtitle">{{ section.settings.pricing_subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="pricing__grid">
      {%- for block in section.blocks -%}
        <div class="pricing-card {% if block.settings.featured %}pricing-card--featured{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.badge_text != blank -%}
            <span class="pricing-card__badge">{{ block.settings.badge_text }}</span>
          {%- endif -%}

          <div class="pricing-card__header">
            <h3 class="pricing-card__plan-name">{{ block.settings.plan_name }}</h3>
            <div class="pricing-card__price">
              <span class="pricing-card__currency">$</span>
              <span class="pricing-card__amount">{{ block.settings.price }}</span>
              <span class="pricing-card__period">/{{ block.settings.period }}</span>
            </div>
          </div>

          <div class="pricing-card__body">
            <ul class="pricing-card__features">
              {%- assign feature_lines = block.settings.features | newline_to_br | split: '<br />' -%}
              {%- for feature in feature_lines -%}
                {%- assign feature_text = feature | strip -%}
                {%- if feature_text != blank -%}
                  <li class="pricing-card__feature">
                    <svg class="pricing-card__feature-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    {{ feature_text }}
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>

          <div class="pricing-card__footer">
            <a href="{{ block.settings.button_link | default: routes.products_url }}" class="pricing-card__button">
              {{ block.settings.button_text }}
            </a>
            {%- if block.settings.guarantee_text != blank -%}
              <p class="pricing-card__guarantee">{{ block.settings.guarantee_text }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Pricing Section",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "pricing_badge",
      "label": "Badge Text",
      "default": "Simple Pricing"
    },
    {
      "type": "text",
      "id": "pricing_title",
      "label": "Heading",
      "default": "Choose Your Plan"
    },
    {
      "type": "textarea",
      "id": "pricing_subtitle",
      "label": "Subheading",
      "default": "Start your transformation today with our all-inclusive subscription."
    }
  ],
  "blocks": [
    {
      "type": "plan",
      "name": "Pricing Plan",
      "settings": [
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge Text (e.g., 'Most Popular')",
          "default": "Most Popular"
        },
        {
          "type": "text",
          "id": "plan_name",
          "label": "Plan Name",
          "default": "Premium"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "149"
        },
        {
          "type": "text",
          "id": "period",
          "label": "Period",
          "default": "month"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Featured Plan",
          "default": true
        },
        {
          "type": "textarea",
          "id": "features",
          "label": "Features (one per line)",
          "default": "Personalized meal plans\nDaily coaching support\nMobile app access\nCommunity membership\nWeekly progress tracking"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Start Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "text",
          "id": "guarantee_text",
          "label": "Guarantee Text",
          "default": "30-day money-back guarantee"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pricing Section",
      "blocks": [
        {
          "type": "plan",
          "settings": {
            "badge_text": "Most Popular",
            "plan_name": "Premium",
            "price": "149",
            "period": "month",
            "featured": true,
            "features": "Personalized meal plans\nDaily coaching support\nMobile app access\nCommunity membership\nWeekly progress tracking",
            "button_text": "Start Now",
            "guarantee_text": "30-day money-back guarantee"
          }
        }
      ]
    }
  ]
}
{% endschema %}
