{%- style -%}
  .medvi-footer {
    background: #121231;
    color: #fff;
    padding: 4rem 0 2rem;
    font-family: 'Red Hat Text', sans-serif;
  }
  
  .medvi-footer__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  
  .medvi-footer__top {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 3rem;
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  
  .medvi-footer__brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .medvi-footer__logo img {
    max-width: 200px;
    height: auto;
  }
  
  .medvi-footer__tagline {
    color: rgba(255,255,255,0.7);
    font-size: 0.9rem;
    line-height: 1.6;
  }
  
  .medvi-footer__links {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
  
  .medvi-footer__column h4 {
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }
  
  .medvi-footer__column ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  
  .medvi-footer__column li {
    margin-bottom: 0.5rem;
  }
  
  .medvi-footer__column a {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.3s ease;
  }
  
  .medvi-footer__column a:hover {
    color: #08a88a;
  }
  
  .medvi-footer__contact {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .medvi-footer__contact-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: rgba(255,255,255,0.7);
    font-size: 0.9rem;
  }
  
  .medvi-footer__contact-item img {
    width: 20px;
    height: 20px;
  }
  
  .medvi-footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  
  .medvi-footer__copyright {
    color: rgba(255,255,255,0.5);
    font-size: 0.85rem;
  }
  
  .medvi-footer__legal {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  
  .medvi-footer__legal a {
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    font-size: 0.85rem;
    transition: color 0.3s ease;
  }
  
  .medvi-footer__legal a:hover {
    color: #08a88a;
  }
  
  .medvi-footer__features {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  
  .medvi-footer__feature {
    text-align: center;
  }
  
  .medvi-footer__feature-icon {
    margin-bottom: 0.75rem;
  }
  
  .medvi-footer__feature-icon img {
    width: 40px;
    height: 40px;
  }
  
  .medvi-footer__feature-text {
    color: rgba(255,255,255,0.9);
    font-size: 0.9rem;
    font-weight: 500;
  }
  
  @media screen and (max-width: 768px) {
    .medvi-footer__top {
      grid-template-columns: 1fr;
    }
    .medvi-footer__links {
      grid-template-columns: repeat(2, 1fr);
    }
    .medvi-footer__features {
      grid-template-columns: repeat(2, 1fr);
    }
    .medvi-footer__bottom {
      flex-direction: column;
      text-align: center;
    }
  }
{%- endstyle -%}

