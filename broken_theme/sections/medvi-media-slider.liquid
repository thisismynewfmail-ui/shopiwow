{%- style -%}
  .medvi-media-slider {
    padding: 3rem 0;
    background: #f8f6f5;
    overflow: hidden;
    position: relative;
  }
  
  .medvi-media-slider__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  
  .medvi-media-slider__track {
    display: flex;
    gap: 4rem;
    animation: scroll 30s linear infinite;
  }
  
  .medvi-media-slider__track:hover {
    animation-play-state: paused;
  }
  
  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  
  .medvi-media-slider__item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .medvi-media-slider__item img {
    max-height: 60px;
    max-width: 180px;
    object-fit: contain;
    opacity: 0.7;
    filter: grayscale(100%);
    transition: all 0.3s ease;
  }
  
  .medvi-media-slider__item img:hover {
    opacity: 1;
    filter: grayscale(0%);
  }
{%- endstyle -%}

<div class="medvi-media-slider">
  <div class="medvi-media-slider__container">
    <div style="text-align: center; margin-bottom: 2rem;">
      <p class="section-paragraph" style="text-align: center;">Proud to be featured and advertised in</p>
    </div>
    <div class="medvi-media-slider__track">
      {% for i in (1..2) %}
      <div class="medvi-media-slider__item">
        <img src="{{ 'bloomberg.png' | asset_url }}" alt="Bloomberg Logo">
      </div>
      <div class="medvi-media-slider__item">
        <img src="{{ 'logo-forbes.png' | asset_url }}" alt="Forbes Logo">
      </div>
      <div class="medvi-media-slider__item">
        <img src="{{ 'logo-healthline.png' | asset_url }}" alt="Healthline Logo">
      </div>
      <div class="medvi-media-slider__item">
        <img src="{{ 'logo-webmd.png' | asset_url }}" alt="WebMD Logo">
      </div>
      <div class="medvi-media-slider__item">
        <img src="{{ 'logo-fortune.png' | asset_url }}" alt="Fortune Logo">
      </div>
      <div class="medvi-media-slider__item">
        <img src="{{ 'logo-fast-company.png' | asset_url }}" alt="Fast Company Logo">
      </div>
      <div class="medvi-media-slider__item">
        <img src="{{ 'logo-the-new-york-times.png' | asset_url }}" alt="New York Times Logo">
      </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Media Slider",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [
    {
      "name": "Media Slider"
    }
  ]
}
{% endschema %}