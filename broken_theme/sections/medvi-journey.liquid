{%- style -%}
  .medvi-journey {
    padding: 5rem 0;
    background: #fff;
  }
  
  .medvi-journey__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  
  .medvi-journey__header {
    margin-bottom: 4rem;
  }
  
  .medvi-journey__title {
    font-size: 2.5rem;
    font-weight: 800;
    color: #121231;
    margin-bottom: 1rem;
  }
  
  .medvi-journey__desc {
    font-size: 1.1rem;
    color: #666;
    max-width: 500px;
  }
  
  .medvi-journey__desc span {
    color: #08a88a;
    font-weight: 600;
  }
  
  .medvi-journey__content {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
  }
  
  .medvi-journey__progress {
    position: relative;
    padding-left: 2rem;
  }
  
  .medvi-journey__progress-line {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: #e4dcd8;
  }
  
  .medvi-journey__progress-bar {
    position: absolute;
    left: 0;
    top: 0;
    width: 3px;
    background: #08a88a;
    height: 0%;
    transition: height 0.5s ease;
  }
  
  .medvi-journey__steps {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
  
  .medvi-journey__step {
    display: flex;
    gap: 2rem;
  }
  
  .medvi-journey__step-dot {
    position: relative;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
  
  .medvi-journey__step-dot::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #fff;
    border: 3px solid #ccc;
  }
  
  .medvi-journey__step-dot::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #08a88a;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  
  .medvi-journey__step.active .medvi-journey__step-dot::before {
    border-color: #08a88a;
  }
  
  .medvi-journey__step.active .medvi-journey__step-dot::after {
    opacity: 1;
  }
  
  .medvi-journey__step-content {
    flex: 1;
  }
  
  .medvi-journey__step-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #121231;
    margin-bottom: 0.75rem;
  }
  
  .medvi-journey__step-text {
    font-size: 1rem;
    color: #666;
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  
  .medvi-journey__step-image {
    border-radius: 12px;
    overflow: hidden;
  }
  
  .medvi-journey__step-image img {
    width: 100%;
    height: auto;
  }
  
  @media screen and (max-width: 992px) {
    .medvi-journey__content {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

<div class="medvi-journey" id="journey">
  <div class="medvi-journey__container">
    <div class="medvi-journey__header">
      <h2 class="medvi-journey__title">Begin your weight loss journey with MEDVi.</h2>
      <p class="medvi-journey__desc">
        Start your transformation today with MEDVi's easy, personalized process for accessing GLP-1 medications. Designed with your convenience in mind, our streamlined approach ensures you're supported <span>every step of the way</span>, from approval to receiving your prescription.
      </p>
    </div>
    
    <div class="medvi-journey__content">
      <div class="medvi-journey__progress">
        <div class="medvi-journey__progress-line">
          <div class="medvi-journey__progress-bar" id="progress-bar"></div>
        </div>
        
        <div class="medvi-journey__steps">
          <div class="medvi-journey__step active">
            <div class="medvi-journey__step-dot"></div>
            <div class="medvi-journey__step-content">
              <h3 class="medvi-journey__step-title">Get Approved</h3>
              <p class="medvi-journey__step-text">Complete a quick online evaluation to determine if GLP-1 medication is right for you. Our team of licensed professionals will review your information and provide approval in no time.</p>
            </div>
          </div>
          
          <div class="medvi-journey__step">
            <div class="medvi-journey__step-dot"></div>
            <div class="medvi-journey__step-content">
              <h3 class="medvi-journey__step-title">Get Prescribed</h3>
              <p class="medvi-journey__step-text">Once approved, you'll receive personalized care and a prescription to support your weight loss and health goals. Your care plan is designed to help you achieve lasting results safely and effectively.</p>
            </div>
          </div>
          
          <div class="medvi-journey__step">
            <div class="medvi-journey__step-dot"></div>
            <div class="medvi-journey__step-content">
              <h3 class="medvi-journey__step-title">Receive your Rx</h3>
              <p class="medvi-journey__step-text">Your medication will be shipped directly to your door for maximum convenience. With MEDVi, starting your treatment is as simple as opening your package and following our easy-to-use instructions.</p>
            </div>
          </div>
        </div>
      </div>
      
      <div class="medvi-journey__gallery">
        <div class="medvi-journey__step-image" style="margin-bottom: 1.5rem;">
          <img src="{{ 'journey-1.jpg' | asset_url }}" alt="Get Approved">
        </div>
        <div class="medvi-journey__step-image" style="margin-bottom: 1.5rem;">
          <img src="{{ 'journey-2.jpg' | asset_url }}" alt="Get Prescribed">
        </div>
        <div class="medvi-journey__step-image">
          <img src="{{ 'journey-3.jpg' | asset_url }}" alt="Receive your Rx">
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const progressBar = document.getElementById('progress-bar');
          if (progressBar) {
            progressBar.style.height = '100%';
          }
        }
      });
    }, { threshold: 0.5 });
    
    const journey = document.querySelector('.medvi-journey');
    if (journey) observer.observe(journey);
  });
</script>

{% schema %}
{
  "name": "MEDVi Journey",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [
    { "name": "MEDVi Journey" }
  ]
}
{% endschema %}