[
  {
    "name": "theme_info",
    "theme_name": "MEDVi Bloom",
    "theme_version": "1.0.0",
    "theme_author": "MEDVi Team",
    "theme_documentation_url": "https://medvi.org",
    "theme_support_url": "https://medvi.org/support"
  },
  {
    "name": "t:settings_schema.colors.name",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "label": "t:settings_schema.colors.settings.background.label",
        "default": "#F7F4F0"
      },
      {
        "type": "color",
        "id": "color_surface",
        "label": "Surface",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "t:settings_schema.colors.settings.text.label",
        "default": "#38312C"
      },
      {
        "type": "color",
        "id": "color_text_muted",
        "label": "Muted text",
        "default": "#6B5E55"
      },
      {
        "type": "color",
        "id": "color_primary",
        "label": "t:settings_schema.colors.settings.primary_button.label",
        "default": "#38312C"
      },
      {
        "type": "color",
        "id": "color_primary_text",
        "label": "t:settings_schema.colors.settings.primary_button_label.label",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "t:settings_schema.colors.settings.secondary_button.label",
        "default": "#779D7C"
      },
      {
        "type": "color",
        "id": "color_secondary_text",
        "label": "t:settings_schema.colors.settings.secondary_button_label.label",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "t:settings_schema.colors.settings.accent.label",
        "default": "#C6A673"
      },
      {
        "type": "color",
        "id": "color_accent_warm",
        "label": "Warm accent",
        "default": "#F5EEE9"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border",
        "default": "#E6DFD5"
      },
      {
        "type": "color",
        "id": "color_success",
        "label": "Success",
        "default": "#779D7C"
      },
      {
        "type": "color",
        "id": "color_error",
        "label": "Error",
        "default": "#B3261E"
      }
    ]
  },
  {
    "name": "t:settings_schema.typography.name",
    "settings": [
      {
        "type": "header",
        "content": "Headings"
      },
      {
        "type": "font_picker",
        "id": "type_header_font",
        "default": "assistant_n7",
        "label": "t:settings_schema.typography.settings.heading_font.label",
        "info": "Red Hat Text is the MEDVi brand font; any system-available font will work."
      },
      {
        "type": "range",
        "id": "heading_scale",
        "min": 100,
        "max": 150,
        "step": 5,
        "unit": "%",
        "label": "t:settings_schema.typography.settings.heading_scale.label",
        "default": 100
      },
      {
        "type": "header",
        "content": "Body"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "default": "assistant_n4",
        "label": "t:settings_schema.typography.settings.body_font.label"
      },
      {
        "type": "range",
        "id": "body_scale",
        "min": 100,
        "max": 130,
        "step": 5,
        "unit": "%",
        "label": "t:settings_schema.typography.settings.body_scale.label",
        "default": 100
      }
    ]
  },
  {
    "name": "t:settings_schema.layout.name",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 1200,
        "max": 1600,
        "step": 20,
        "default": 1280,
        "unit": "px",
        "label": "t:settings_schema.layout.settings.page_width.label"
      },
      {
        "type": "range",
        "id": "spacing_sections",
        "min": 0,
        "max": 120,
        "step": 4,
        "unit": "px",
        "label": "t:settings_schema.layout.settings.section_spacing.label",
        "default": 80
      },
      {
        "type": "range",
        "id": "card_radius",
        "min": 0,
        "max": 40,
        "step": 2,
        "unit": "px",
        "label": "t:settings_schema.layout.settings.card_border_radius.label",
        "default": 16
      },
      {
        "type": "range",
        "id": "button_radius",
        "min": 0,
        "max": 40,
        "step": 2,
        "unit": "px",
        "label": "Button corner radius",
        "default": 32
      }
    ]
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 80,
        "max": 260,
        "step": 10,
        "default": 180,
        "unit": "px",
        "label": "Logo width"
      },
      {
        "type": "text",
        "id": "brand_tagline",
        "label": "Brand tagline",
        "default": "Personalized Weight Loss, Doctor-Guided."
      }
    ]
  },
  {
    "name": "t:settings_schema.social.name",
    "settings": [
      {
        "type": "header",
        "content": "Social accounts"
      },
      {
        "type": "text",
        "id": "social_facebook_link",
        "label": "t:settings_schema.social.settings.social_facebook_link.label"
      },
      {
        "type": "text",
        "id": "social_instagram_link",
        "label": "t:settings_schema.social.settings.social_instagram_link.label"
      },
      {
        "type": "text",
        "id": "social_twitter_link",
        "label": "t:settings_schema.social.settings.social_twitter_link.label"
      },
      {
        "type": "text",
        "id": "social_youtube_link",
        "label": "t:settings_schema.social.settings.social_youtube_link.label"
      },
      {
        "type": "text",
        "id": "social_tiktok_link",
        "label": "t:settings_schema.social.settings.social_tiktok_link.label"
      }
    ]
  },
  {
    "name": "t:settings_schema.favicon.name",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "t:settings_schema.favicon.settings.favicon.label",
        "info": "Will be scaled down to 32 x 32px"
      }
    ]
  },
  {
    "name": "t:settings_schema.cart.name",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "t:settings_schema.cart.settings.cart_type.label",
        "default": "drawer",
        "options": [
          {
            "value": "drawer",
            "label": "t:settings_schema.cart.settings.cart_type.options__1.label"
          },
          {
            "value": "page",
            "label": "t:settings_schema.cart.settings.cart_type.options__2.label"
          }
        ]
      },
      {
        "type": "checkbox",
        "id": "show_cart_note",
        "label": "t:settings_schema.cart.settings.show_cart_note.label",
        "default": false
      }
    ]
  }
]
