{%- style -%}
  .medvi-announcement {
    background: #000;
    color: #fff;
    padding: 10px 16px;
    font-family: var(--font-body);
    position: relative;
    z-index: 1001;
  }

  .medvi-announcement__inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
    text-align: center;
  }

  .medvi-announcement__pill {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px;
    border-radius: 999px;
    background: linear-gradient(135deg, #fde68a, #c6a673 55%, #c6a673);
    color: #000;
    font-weight: 700;
    text-decoration: none;
    font-size: 0.95rem;
  }

  .medvi-announcement__sub {
    font-size: 0.9rem;
    font-weight: 500;
    opacity: 0.95;
  }

  .medvi-announcement__countdown {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.12);
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .medvi-announcement__countdown span {
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 640px) {
    .medvi-announcement__sub { display: none; }
  }
{%- endstyle -%}

<div class="medvi-announcement">
  <div class="medvi-announcement__inner">
    <a class="medvi-announcement__pill" href="{{ section.settings.cta_link | default: '/pages/intake-form' }}">
      <span>{{ section.settings.headline | default: 'SPRING Discount Applied!' }}</span>
      <span>&rarr;</span>
    </a>
    <span class="medvi-announcement__sub">{{ section.settings.subtext | default: 'Just $179 + Fast, Free Shipping — Fully backed by our weight loss guarantee.' }}</span>
    {%- if settings.enable_countdown -%}
      <span class="medvi-announcement__countdown" aria-live="polite">
        <span>{{ settings.countdown_text }}</span>
        <span id="medviCountdown">--:--:--</span>
      </span>
    {%- endif -%}
  </div>
</div>

{%- if settings.enable_countdown -%}
<script>
  (function() {
    var el = document.getElementById('medviCountdown');
    if (!el) return;
    var hours = {{ settings.countdown_hours | default: 12 }};
    var key = 'medvi_countdown_end';
    var now = Date.now();
    var end = parseInt(localStorage.getItem(key) || '0', 10);
    if (!end || end < now) {
      end = now + hours * 3600000;
      localStorage.setItem(key, end);
    }
    function pad(n) { return n < 10 ? '0' + n : '' + n; }
    function tick() {
      var diff = Math.max(0, end - Date.now());
      var h = Math.floor(diff / 3600000);
      var m = Math.floor((diff % 3600000) / 60000);
      var s = Math.floor((diff % 60000) / 1000);
      el.textContent = pad(h) + ':' + pad(m) + ':' + pad(s);
      if (diff <= 0) {
        localStorage.removeItem(key);
        clearInterval(t);
      }
    }
    tick();
    var t = setInterval(tick, 1000);
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "section",
  "class": "section-announcement",
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "SPRING Discount Applied!"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Sub text",
      "default": "Just $179 + Fast, Free Shipping — Fully backed by our weight loss guarantee."
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    }
  ],
  "presets": [
    { "name": "Announcement Bar" }
  ]
}
{% endschema %}
