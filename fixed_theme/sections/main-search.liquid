{%- style -%}
  .main-search { padding: 4rem 0 5rem; }
  .main-search__header { text-align: center; margin-bottom: 2rem; }
  .main-search__title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }
  .main-search__form {
    display: flex;
    max-width: 560px;
    margin: 0 auto 2rem;
    gap: 0.5rem;
  }
  .main-search__form input {
    flex: 1;
    padding: 0.875rem 1rem;
    border: 2px solid #e4dcd8;
    border-radius: 10px;
    font-size: 1rem;
    font-family: inherit;
  }
  .main-search__form input:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  .main-search__form button {
    padding: 0.875rem 1.5rem;
    background: var(--color-accent);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-weight: 700;
    cursor: pointer;
  }
  .main-search__form button:hover { background: var(--color-accent-hover); }
  .main-search__results {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }
{%- endstyle -%}

<section class="main-search">
  <div class="container">
    <div class="main-search__header">
      <h1 class="main-search__title">{{ 'general.search.title' | t }}</h1>
    </div>
    <form action="{{ routes.search_url }}" class="main-search__form" method="get" role="search">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.placeholder' | t }}">
      <button type="submit">{{ 'general.search.submit' | t }}</button>
    </form>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <p style="text-align:center;color:var(--color-text-muted);margin-bottom:2rem;">
          {{ 'general.search.results_with_count' | t: count: search.results_count, terms: search.terms }}
        </p>
        <div class="main-search__results">
          {%- for item in search.results -%}
            <a class="product-card" href="{{ item.url }}" style="background:#fff;border-radius:12px;box-shadow:0 4px 14px rgba(0,0,0,0.05);overflow:hidden;text-decoration:none;color:inherit;">
              {%- if item.featured_image -%}
                <img src="{{ item.featured_image | image_url: width: 600 }}" alt="{{ item.title | escape }}" style="width:100%;aspect-ratio:1;object-fit:cover;">
              {%- endif -%}
              <div style="padding:1rem 1.25rem;">
                <h2 style="font-size:1rem;font-weight:700;color:var(--color-primary);margin:0;">{{ item.title }}</h2>
              </div>
            </a>
          {%- endfor -%}
        </div>
      {%- else -%}
        <p style="text-align:center;color:var(--color-text-muted);">
          {{ 'general.search.no_results_html' | t: terms: search.terms }}
        </p>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Search",
  "tag": "section",
  "class": "section-main-search",
  "settings": []
}
{% endschema %}
