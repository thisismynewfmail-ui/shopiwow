{%- style -%}
  .main-gift-card {
    padding: 4rem 1.5rem 5rem;
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }
  .main-gift-card__eyebrow {
    color: var(--color-accent);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
  }
  .main-gift-card__title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }
  .main-gift-card__value {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-accent);
    margin: 1rem 0 2rem;
  }
  .main-gift-card__image {
    width: 100%;
    border-radius: 18px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    margin-bottom: 2rem;
  }
  .main-gift-card__code {
    background: #fff;
    border: 2px dashed var(--color-accent);
    border-radius: 12px;
    padding: 1.25rem;
    font-family: 'Courier New', monospace;
    font-size: 1.25rem;
    letter-spacing: 0.12em;
    margin-bottom: 1.5rem;
    word-break: break-all;
  }
  .main-gift-card__actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .main-gift-card__expired {
    color: #c0392b;
    font-weight: 700;
    margin-top: 1rem;
  }
{%- endstyle -%}

<section class="main-gift-card">
  <div class="main-gift-card__eyebrow">{{ 'gift_cards.issued.subtext' | t }}</div>
  <h1 class="main-gift-card__title">{{ 'gift_cards.issued.title' | t }}</h1>
  <div class="main-gift-card__value">{{ gift_card.initial_value | money }}</div>

  {%- if gift_card.image -%}
    <img class="main-gift-card__image" src="{{ gift_card.image | image_url: width: 1200 }}" alt="{{ 'gift_cards.issued.title' | t }}">
  {%- endif -%}

  <div class="main-gift-card__code">{{ gift_card.code | format_code }}</div>

  {%- if gift_card.enabled == false or gift_card.expired -%}
    <p class="main-gift-card__expired">{{ 'gift_cards.issued.expired' | t }}</p>
  {%- else -%}
    <p style="color:var(--color-text-muted);margin-bottom:1.5rem;">
      {{ 'gift_cards.issued.remaining_html' | t: balance: gift_card.balance | money }}
    </p>
  {%- endif -%}

  <div class="main-gift-card__actions">
    <a href="{{ gift_card.pass_url }}" class="btn btn--secondary">{{ 'gift_cards.issued.add_to_apple_wallet' | t }}</a>
    <a href="{{ shop.url }}" class="btn btn--primary">{{ 'gift_cards.issued.shop_link' | t }}</a>
  </div>
</section>

{% schema %}
{
  "name": "Gift card",
  "tag": "section",
  "class": "section-main-gift-card",
  "settings": []
}
{% endschema %}
