<section class="section" id="the-numbers">
  <div class="container">
    <div class="stats">
      <div class="section-header" style="color:var(--color-primary-text); max-width:720px;">
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow eyebrow--gold">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="mt-sm" style="color:var(--color-primary-text);">{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p style="color:var(--color-primary-text); opacity:.9;">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
      <div class="stats__grid mt-lg">
        {%- for block in section.blocks -%}
          <div {{ block.shopify_attributes }}>
            <div class="stats__number" data-counter data-target="{{ block.settings.number_value }}">
              {{ block.settings.number_prefix }}{{ block.settings.number_value }}{{ block.settings.number_suffix }}
            </div>
            <div class="stats__label">{{ block.settings.label }}</div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Stats / The numbers",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The numbers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why are so many patients signing up for MEDVi? It works."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "It's not magic—it's metabolic science. GLP-1 regulates appetite and blood sugar so you work with your body, not against it."
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "number_prefix", "label": "Prefix" },
        { "type": "text", "id": "number_value", "label": "Value", "default": "500,000" },
        { "type": "text", "id": "number_suffix", "label": "Suffix", "default": "+" },
        { "type": "text", "id": "label", "label": "Label", "default": "Patients served" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Stats",
      "category": "Trust",
      "blocks": [
        { "type": "stat", "settings": { "number_value": "500,000", "number_suffix": "+", "label": "Patients served" } },
        { "type": "stat", "settings": { "number_value": "15-20", "number_suffix": "%", "label": "Average weight loss" } },
        { "type": "stat", "settings": { "number_value": "1-2", "number_suffix": "lbs", "label": "Lost per week, on average" } },
        { "type": "stat", "settings": { "number_value": "24/7", "number_suffix": "", "label": "Doctor-led support" } }
      ]
    }
  ]
}
{% endschema %}
