{%- style -%}
  .main-cart { padding: 4rem 0 5rem; }
  .main-cart__title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 2rem;
  }
  .main-cart__table {
    width: 100%;
    border-collapse: collapse;
  }
  .main-cart__table th,
  .main-cart__table td {
    padding: 1rem;
    border-bottom: 1px solid #eee;
    text-align: left;
    vertical-align: middle;
  }
  .main-cart__image {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 10px;
    background: var(--color-background-alt);
  }
  .main-cart__qty {
    width: 80px;
    padding: 0.5rem;
    border: 1px solid #e4dcd8;
    border-radius: 8px;
    font-family: inherit;
  }
  .main-cart__footer {
    margin-top: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .main-cart__subtotal {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-primary);
  }
  .main-cart__actions { display: flex; gap: 0.75rem; }
  .main-cart__btn {
    padding: 0.9rem 1.5rem;
    border-radius: 10px;
    font-weight: 700;
    cursor: pointer;
    border: none;
    font-size: 1rem;
    font-family: inherit;
  }
  .main-cart__btn--primary { background: var(--color-accent); color: #fff; }
  .main-cart__btn--primary:hover { background: var(--color-accent-hover); }
  .main-cart__btn--secondary { background: var(--color-background-alt); color: var(--color-primary); }
  .main-cart__empty {
    text-align: center;
    padding: 4rem 0;
    color: var(--color-text-muted);
  }
  .main-cart__empty a { color: var(--color-accent); font-weight: 700; }
{%- endstyle -%}

<section class="main-cart">
  <div class="container" style="max-width: 1000px;">
    <h1 class="main-cart__title">{{ 'sections.cart.title' | t }}</h1>

    {%- if cart.item_count > 0 -%}
      {%- form 'cart', cart -%}
        <table class="main-cart__table">
          <thead>
            <tr>
              <th colspan="2">Product</th>
              <th>{{ 'products.product.quantity' | t }}</th>
              <th>{{ 'sections.cart.subtotal' | t }}</th>
            </tr>
          </thead>
          <tbody>
            {%- for item in cart.items -%}
              <tr>
                <td>
                  {%- if item.image != blank -%}
                    <img class="main-cart__image" src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}">
                  {%- endif -%}
                </td>
                <td>
                  <a href="{{ item.url }}" style="color:var(--color-primary);font-weight:600;">{{ item.product.title }}</a>
                  {%- unless item.product.has_only_default_variant -%}
                    <div style="font-size:0.85rem;color:var(--color-text-muted);">{{ item.variant.title }}</div>
                  {%- endunless -%}
                </td>
                <td>
                  <input class="main-cart__qty" type="number" name="updates[]" value="{{ item.quantity }}" min="0" aria-label="{{ 'products.product.quantity' | t }}">
                </td>
                <td><strong>{{ item.final_line_price | money }}</strong></td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>

        <div class="main-cart__footer">
          <div class="main-cart__subtotal">
            {{ 'sections.cart.subtotal' | t }}: {{ cart.total_price | money }}
          </div>
          <div class="main-cart__actions">
            <button type="submit" name="update" class="main-cart__btn main-cart__btn--secondary">{{ 'sections.cart.update' | t }}</button>
            <button type="submit" name="checkout" class="main-cart__btn main-cart__btn--primary">{{ 'sections.cart.checkout' | t }}</button>
          </div>
        </div>
      {%- endform -%}
    {%- else -%}
      <div class="main-cart__empty">
        <p>{{ 'sections.cart.empty' | t }}</p>
        <p><a href="{{ routes.all_products_collection_url }}">{{ 'sections.cart.continue_shopping' | t }} &rarr;</a></p>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "class": "section-main-cart",
  "settings": []
}
{% endschema %}
