{%- style -%}
  .main-password {
    padding: 6rem 2rem;
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }
  .main-password__title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }
  .main-password__form { display: flex; gap: 0.5rem; margin-top: 2rem; }
  .main-password__form input {
    flex: 1;
    padding: 0.875rem 1rem;
    border: 2px solid #e4dcd8;
    border-radius: 10px;
    font-family: inherit;
  }
  .main-password__form button {
    padding: 0.875rem 1.5rem;
    background: var(--color-accent);
    color: #fff;
    border: 0;
    border-radius: 10px;
    font-weight: 700;
    cursor: pointer;
  }
{%- endstyle -%}

<section class="main-password">
  <h1 class="main-password__title">{{ 'general.password_page.opening_soon' | t }}</h1>
  <p>{{ shop.password_message }}</p>
  {%- form 'storefront_password', class: 'main-password__form' -%}
    <input type="password" name="password" placeholder="{{ 'general.password_page.login_form_password_placeholder' | t }}">
    <button type="submit">{{ 'general.password_page.login_form_submit' | t }}</button>
    {{ form.errors | default_errors }}
  {%- endform -%}
</section>

{% schema %}
{
  "name": "Password",
  "tag": "section",
  "class": "section-main-password",
  "settings": []
}
{% endschema %}
