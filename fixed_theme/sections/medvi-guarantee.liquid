{%- style -%}
  .medvi-guarantee {
    padding: 5rem 0;
    background: var(--color-background-alt);
  }
  .medvi-guarantee__inner {
    background: linear-gradient(135deg, #121231, #1a1a3e);
    color: #fff;
    border-radius: 24px;
    padding: 3rem;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 3rem;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .medvi-guarantee__inner::before {
    content: '';
    position: absolute;
    top: -80px; right: -80px;
    width: 300px; height: 300px;
    background: radial-gradient(circle, rgba(8,168,138,0.3), transparent 70%);
  }
  .medvi-guarantee__badge {
    text-align: center;
    position: relative;
    z-index: 1;
  }
  .medvi-guarantee__badge img {
    width: 220px;
    margin: 0 auto;
    filter: drop-shadow(0 8px 16px rgba(0,0,0,0.2));
  }
  .medvi-guarantee__body { position: relative; z-index: 1; }
  .medvi-guarantee__title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    color: #fff;
    margin-bottom: 0.75rem;
  }
  .medvi-guarantee__title em { color: var(--color-accent); font-style: normal; }
  .medvi-guarantee__text {
    color: rgba(255,255,255,0.85);
    margin-bottom: 1.75rem;
    font-size: 1.02rem;
    line-height: 1.65;
  }
  .medvi-guarantee__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    align-items: center;
  }
  .medvi-guarantee__cta {
    background: var(--color-accent);
    color: #fff;
    padding: 1rem 1.75rem;
    border-radius: 10px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.25s ease;
  }
  .medvi-guarantee__cta:hover {
    background: var(--color-accent-hover);
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(8,168,138,0.4);
  }
  .medvi-guarantee__meta {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.65);
  }

  @media (max-width: 768px) {
    .medvi-guarantee__inner { grid-template-columns: 1fr; padding: 2rem; }
    .medvi-guarantee__badge img { width: 160px; }
  }
{%- endstyle -%}

<section class="medvi-guarantee" id="guarantee">
  <div class="container">
    <div class="medvi-guarantee__inner">
      <div class="medvi-guarantee__badge">
        <img src="{{ 'guarantee-circle.svg' | asset_url }}" alt="MEDVi Guarantee">
      </div>
      <div class="medvi-guarantee__body">
        <h2 class="medvi-guarantee__title">
          {{ section.settings.title | default: 'The MEDVi Guarantee —' }} <em>{{ section.settings.title_highlight | default: "the only thing you'll lose is extra weight." }}</em>
        </h2>
        <p class="medvi-guarantee__text">
          {{ section.settings.text | default: "With over 500,000+ patients, we're confident you will reach your goal with our personalized program. If you don't see results, we'll make it right." }}
        </p>
        <div class="medvi-guarantee__actions">
          <a href="{{ section.settings.cta_link | default: '/pages/intake-form' }}" class="medvi-guarantee__cta">
            {{ section.settings.cta_text | default: 'Continue with confidence' }} &rarr;
          </a>
          <span class="medvi-guarantee__meta">HSA/FSA approved · No insurance required · Free shipping</span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Guarantee",
  "tag": "section",
  "class": "section-guarantee",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "The MEDVi Guarantee —" },
    { "type": "text", "id": "title_highlight", "label": "Title highlight", "default": "the only thing you'll lose is extra weight." },
    { "type": "textarea", "id": "text", "label": "Body" },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Continue with confidence" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "presets": [ { "name": "Guarantee" } ]
}
{% endschema %}
