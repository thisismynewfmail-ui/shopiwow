{%- style -%}
  .medvi-hero {
    position: relative;
    padding: 4rem 0 5rem;
    background: linear-gradient(135deg, {{ section.settings.bg_from | default: '#121231' }} 0%, {{ section.settings.bg_to | default: '#1a1a3e' }} 100%);
    color: #fff;
    overflow: hidden;
  }

  .medvi-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 20% 20%, rgba(8,168,138,0.18), transparent 55%),
                radial-gradient(circle at 80% 80%, rgba(255,255,255,0.06), transparent 55%);
    pointer-events: none;
  }

  .medvi-hero__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 2;
  }

  .medvi-hero__grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .medvi-hero__text { color: #fff; }

  .medvi-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(8,168,138,0.15);
    border: 1px solid rgba(8,168,138,0.4);
    color: #fff;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
  }

  .medvi-hero__eyebrow strong { color: var(--color-accent); }

  .medvi-hero__title {
    font-size: clamp(2rem, 4.2vw, 3.4rem);
    font-weight: 800;
    line-height: 1.15;
    margin: 0 0 1.25rem;
  }

  .medvi-hero__title em {
    color: var(--color-accent);
    font-style: normal;
    font-weight: 800;
  }

  .medvi-hero__subtitle {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.85);
    margin-bottom: 1.5rem;
    max-width: 560px;
  }

  .medvi-hero__checklist {
    display: grid;
    gap: 0.75rem;
    margin: 0 0 2rem;
    padding: 0;
    list-style: none;
  }

  .medvi-hero__checklist li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 1rem;
  }

  .medvi-hero__checklist img {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .medvi-hero__checklist strong {
    color: var(--color-accent);
    font-weight: 700;
  }

  .medvi-hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .medvi-hero__cta {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    padding: 1rem 2rem;
    border-radius: 10px;
    font-size: 1.05rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .medvi-hero__cta:hover {
    background: var(--color-accent-hover);
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(8,168,138,0.4);
  }

  .medvi-hero__reassure {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.75);
  }

  .medvi-hero__stars { display: flex; gap: 2px; }
  .medvi-hero__stars svg { width: 16px; height: 16px; fill: #f5c443; }

  .medvi-hero__collage {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 140px;
    gap: 14px;
  }

  .medvi-hero__collage-item {
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.25);
    position: relative;
  }

  .medvi-hero__collage-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .medvi-hero__collage-item:nth-child(1) { grid-row: span 2; }
  .medvi-hero__collage-item:nth-child(4) { grid-row: span 2; }

  .medvi-hero__collage-badge {
    position: absolute;
    bottom: 10px;
    left: 10px;
    background: rgba(255,255,255,0.9);
    color: var(--color-primary);
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 700;
  }

  @media (max-width: 992px) {
    .medvi-hero__grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .medvi-hero__collage { grid-auto-rows: 110px; }
  }

  @media (max-width: 576px) {
    .medvi-hero__collage {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 140px;
    }
    .medvi-hero__collage-item:nth-child(5) { display: none; }
  }
{%- endstyle -%}

<section class="medvi-hero">
  <div class="medvi-hero__container">
    <div class="medvi-hero__grid">
      <div class="medvi-hero__text">
        <span class="medvi-hero__eyebrow">Join <strong>500,000+</strong> MEDVi patients</span>
        <h1 class="medvi-hero__title">
          {{ section.settings.title_before | default: 'Finally serious about weight loss?' }}
          <em>{{ section.settings.title_highlight | default: 'Fat loss made easy' }}</em>
          {{ section.settings.title_after | default: 'with personalized care and GLP-1 medication.' }}
        </h1>
        <p class="medvi-hero__subtitle">
          {{ section.settings.subtitle | default: "Doctor-led GLP-1 treatment, personalized coaching, and medication shipped to your door — all starting at just $179 with no membership fees." }}
        </p>

        <ul class="medvi-hero__checklist">
          <li><img src="{{ 'checkmark-icon-white.svg' | asset_url }}" alt=""><span><strong>Lose pounds of fat every week</strong></span></li>
          <li><img src="{{ 'checkmark-icon-white.svg' | asset_url }}" alt=""><span><strong>MEDVi Guarantee</strong> — the only thing you'll lose is extra weight</span></li>
          <li><img src="{{ 'checkmark-icon-white.svg' | asset_url }}" alt=""><span><strong>No membership</strong> or hidden fees</span></li>
          <li><img src="{{ 'checkmark-icon-white.svg' | asset_url }}" alt=""><span>Start for <strong>just $179</strong> — no insurance required + free shipping</span></li>
          <li><img src="{{ 'checkmark-icon-white.svg' | asset_url }}" alt=""><span><strong>HSA/FSA approved</strong></span></li>
        </ul>

        <div class="medvi-hero__actions">
          <a href="{{ section.settings.cta_link | default: '/pages/intake-form' }}" class="medvi-hero__cta">
            {{ section.settings.cta_text | default: 'Am I Qualified?' }} &rarr;
          </a>
          <span class="medvi-hero__reassure">
            <span class="medvi-hero__stars" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </span>
            10,000+ 5-star reviews
          </span>
        </div>
      </div>

      <div class="medvi-hero__collage" aria-hidden="true">
        <div class="medvi-hero__collage-item">
          <img src="{{ 'hero-grid-9.jpg' | asset_url }}" alt="Patient transformation" loading="eager">
          <span class="medvi-hero__collage-badge">Lost 34 lbs</span>
        </div>
        <div class="medvi-hero__collage-item">
          <img src="{{ 'hero-grid-4.jpg' | asset_url }}" alt="Patient result" loading="eager">
        </div>
        <div class="medvi-hero__collage-item">
          <img src="{{ 'hero-grid-3.jpg' | asset_url }}" alt="Patient result" loading="eager">
        </div>
        <div class="medvi-hero__collage-item">
          <img src="{{ 'hero-grid-8.jpg' | asset_url }}" alt="Patient result" loading="eager">
          <span class="medvi-hero__collage-badge">Lost 52 lbs</span>
        </div>
        <div class="medvi-hero__collage-item">
          <img src="{{ 'hero-grid-6b.jpg' | asset_url }}" alt="Patient result" loading="eager">
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    { "type": "text", "id": "title_before", "label": "Title – Before highlight", "default": "Finally serious about weight loss?" },
    { "type": "text", "id": "title_highlight", "label": "Title – Highlighted phrase", "default": "Fat loss made easy" },
    { "type": "text", "id": "title_after", "label": "Title – After highlight", "default": "with personalized care and GLP-1 medication." },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Doctor-led GLP-1 treatment, personalized coaching, and medication shipped to your door — all starting at just $179 with no membership fees." },
    { "type": "text", "id": "cta_text", "label": "CTA Text", "default": "Am I Qualified?" },
    { "type": "url", "id": "cta_link", "label": "CTA Link" },
    { "type": "color", "id": "bg_from", "label": "Background gradient – From", "default": "#121231" },
    { "type": "color", "id": "bg_to", "label": "Background gradient – To", "default": "#1a1a3e" }
  ],
  "presets": [ { "name": "Hero" } ]
}
{% endschema %}
