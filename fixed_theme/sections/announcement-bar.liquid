{%- if section.blocks.size > 0 -%}
  <div class="announcement-bar" data-announcement>
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'announcement' -%}
          <div class="announcement-bar__item" {{ block.shopify_attributes }}>
            {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}">{%- endif -%}
            {{ block.settings.text | escape }}
            {%- if block.settings.link != blank -%}</a>{%- endif -%}
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Free, fast shipping on every order — start for $179, no contract.",
          "label": "Announcement text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "announcement",
        "settings": {
          "text": "Free, fast shipping on every order — start for $179, no contract."
        }
      },
      {
        "type": "announcement",
        "settings": {
          "text": "Over 500,000 patients trust MEDVi for real, lasting weight loss."
        }
      }
    ]
  },
  "enabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
