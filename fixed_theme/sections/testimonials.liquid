<section class="section" id="reviews">
  <div class="container">
    <div class="section-header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="mt-sm">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="testimonials">
      {%- for block in section.blocks -%}
        <article class="testimonial reveal" {{ block.shopify_attributes }}>
          <div class="testimonial__stars" aria-label="5 out of 5 stars">★★★★★</div>
          <blockquote class="testimonial__quote">&ldquo;{{ block.settings.quote }}&rdquo;</blockquote>
          <div class="testimonial__person">
            <div class="testimonial__avatar">
              {%- if block.settings.avatar != blank -%}
                <img src="{{ block.settings.avatar | image_url: width: 160 }}" alt="{{ block.settings.name | escape }}" loading="lazy">
              {%- else -%}
                <div style="background: var(--color-sand-light); width:100%; height:100%; display:flex; align-items:center; justify-content:center; color: var(--color-primary); font-weight:700;">{{ block.settings.name | slice: 0, 1 }}</div>
              {%- endif -%}
            </div>
            <div>
              <div class="testimonial__name">{{ block.settings.name }}</div>
              <div class="testimonial__meta">{{ block.settings.meta | default: 'Verified patient' }}</div>
            </div>
          </div>
        </article>
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div class="text-center mt-lg">
        <a href="{{ section.settings.cta_link | default: routes.all_products_collection_url }}" class="btn btn--outline">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why patients rave" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "There's a reason people are raving about us." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Join the thousands of people who have trusted MEDVi to help change their lives, achieving significant, lasting weight loss." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Read more reviews" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "image_picker", "id": "avatar", "label": "Avatar" },
        { "type": "text", "id": "name", "label": "Name", "default": "Belinda" },
        { "type": "text", "id": "meta", "label": "Meta", "default": "Verified patient · 6 months" },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "Losing weight without a crazy diet, without cardio — it just felt like magic. I was a snacker, but not anymore." }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Testimonials",
      "category": "Trust",
      "blocks": [
        { "type": "review", "settings": { "name": "Belinda", "quote": "My experience is very positive. I am doing very well. Slowly and surely reaching my goals with MEDVi's help. They have been very attentive and have provided me with all the resources to be successful." } },
        { "type": "review", "settings": { "name": "Greg", "quote": "I was ready to give up. Wow. I would pay 10x as much if I had to. Dieting days are over. Thanks to the guys at MEDVi for the metabolic fix — game changer." } },
        { "type": "review", "settings": { "name": "Melissa", "quote": "Losing weight without a crazy diet, without cardio… it just felt like magic. I was a snacker, but not anymore. I feel so much better." } },
        { "type": "review", "settings": { "name": "Chris", "quote": "The staff has been so friendly and caring. I didn't expect that! If I call, I get an immediate answer from a real person!" } },
        { "type": "review", "settings": { "name": "Terri", "quote": "The questions are to the point and easy to navigate. I'm able to voice my concerns if needed and ask questions of MEDVi. They are quick to respond and keep me updated on my prescription." } },
        { "type": "review", "settings": { "name": "Sandra", "quote": "MEDVi doctors and staff have been very professional and prompt with any questions I have. I feel in great hands! I'm 13 lbs away from my goal." } }
      ]
    }
  ]
}
{% endschema %}
