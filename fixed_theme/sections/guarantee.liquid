<section class="section" id="guarantee">
  <div class="container">
    <div class="guarantee">
      <div class="guarantee__seal">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 560 }}" alt="{{ section.settings.heading | escape }}" loading="lazy">
        {%- else -%}
          <img src="{{ 'guarantee-circle.svg' | asset_url }}" alt="MEDVi Guarantee" loading="lazy">
        {%- endif -%}
      </div>
      <div>
        <span class="eyebrow eyebrow--gold">{{ section.settings.eyebrow }}</span>
        <h2 class="mt-sm">{{ section.settings.heading }}</h2>
        <p>{{ section.settings.text }}</p>
        <a href="{{ section.settings.cta_link | default: routes.all_products_collection_url }}" class="btn btn--primary btn--lg mt-md">
          {{ section.settings.cta_label | default: 'Continue with confidence' }}
          {% render 'icon', icon: 'arrow-right' %}
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Guarantee",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "MEDVi Guarantee" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The only thing you'll lose is extra weight." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "With over 500,000+ patients, we're confident you will reach your goal with our personalized program." },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Continue with confidence" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "presets": [{ "name": "Guarantee", "category": "Trust" }]
}
{% endschema %}
