{%- style -%}
  .main-article { padding: 4rem 0 5rem; max-width: 820px; margin: 0 auto; }
  .main-article__meta { color: var(--color-accent); font-weight: 600; font-size: 0.9rem; margin-bottom: 0.5rem; }
  .main-article__title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }
  .main-article__author { color: var(--color-text-muted); margin-bottom: 2rem; font-size: 0.95rem; }
  .main-article__cover {
    width: 100%;
    border-radius: 16px;
    margin-bottom: 2rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
  }
  .main-article__content { line-height: 1.8; color: var(--color-text); font-size: 1.05rem; }
  .main-article__content p { margin: 0 0 1.25rem; }
  .main-article__content a { color: var(--color-accent); }
  .main-article__content img { border-radius: 12px; }
{%- endstyle -%}

<article class="main-article container">
  <div class="main-article__meta">{{ article.published_at | date: format: 'month_day_year' }}</div>
  <h1 class="main-article__title">{{ article.title }}</h1>
  <div class="main-article__author">By {{ article.author }}</div>
  {%- if article.image != blank -%}
    <img class="main-article__cover" src="{{ article.image | image_url: width: 1400 }}" alt="{{ article.image.alt | escape | default: article.title }}">
  {%- endif -%}
  <div class="main-article__content rte">{{ article.content }}</div>
</article>

{% schema %}
{
  "name": "Article",
  "tag": "section",
  "class": "section-main-article",
  "settings": []
}
{% endschema %}
