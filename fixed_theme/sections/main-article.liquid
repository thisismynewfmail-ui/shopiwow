<article class="section">
  <div class="container">
    <div style="max-width: 760px; margin: 0 auto;">
      <a href="{{ blog.url }}" class="text-muted" style="font-size:.875rem;">← {{ 'blogs.article.back_to_blog' | t }}</a>
      <header style="margin-top: 16px; margin-bottom: 32px;">
        <span class="eyebrow">{{ blog.title }}</span>
        <h1 class="mt-sm">{{ article.title }}</h1>
        <p class="text-muted">{{ article.published_at | date: '%B %d, %Y' }}{% if article.author %} · {{ article.author }}{% endif %}</p>
      </header>

      {%- if article.image -%}
        <img src="{{ article.image | image_url: width: 1400 }}" alt="{{ article.image.alt | default: article.title | escape }}" style="width:100%; border-radius: var(--card-radius); margin-bottom: 32px;" loading="lazy">
      {%- endif -%}

      <div class="rte">{{ article.content }}</div>

      {%- if blog.comments_enabled? -%}
        <section style="margin-top: 48px; padding-top: 32px; border-top: 1px solid var(--color-border);">
          <h2>{{ 'blogs.article.comments' | t: count: article.comments_count }}</h2>
          {%- for comment in article.comments -%}
            <div class="card mb-md">
              <strong>{{ comment.author }}</strong>
              <small class="text-muted" style="margin-left:8px;">{{ comment.created_at | date: '%B %d, %Y' }}</small>
              <div class="rte mt-sm">{{ comment.content }}</div>
            </div>
          {%- endfor -%}

          {%- form 'new_comment', article -%}
            <div class="grid grid--2">
              <div class="field">
                <label for="comment-author">{{ 'blogs.article.name' | t }}</label>
                <input id="comment-author" type="text" name="comment[author]" required>
              </div>
              <div class="field">
                <label for="comment-email">{{ 'blogs.article.email' | t }}</label>
                <input id="comment-email" type="email" name="comment[email]" required>
              </div>
            </div>
            <div class="field">
              <label for="comment-body">{{ 'blogs.article.message' | t }}</label>
              <textarea id="comment-body" name="comment[body]" rows="5" required></textarea>
            </div>
            <button type="submit" class="btn btn--primary">{{ 'blogs.article.post' | t }}</button>
          {%- endform -%}
        </section>
      {%- endif -%}
    </div>
  </div>
</article>

{% schema %}
{
  "name": "Article",
  "settings": []
}
{% endschema %}
