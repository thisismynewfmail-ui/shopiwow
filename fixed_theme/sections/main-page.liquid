{%- style -%}
  .main-page {
    padding: 4rem 0 5rem;
    max-width: 820px;
    margin: 0 auto;
  }
  .main-page__title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    margin-bottom: 1.25rem;
    color: var(--color-primary);
  }
  .main-page__content {
    line-height: 1.75;
    color: var(--color-text);
    font-size: 1.05rem;
  }
  .main-page__content p { margin: 0 0 1rem; }
  .main-page__content h2,
  .main-page__content h3 { margin-top: 2rem; }
  .main-page__content a { color: var(--color-accent); }
  .main-page__content ul,
  .main-page__content ol { padding-left: 1.5rem; margin-bottom: 1rem; }
{%- endstyle -%}

<article class="main-page container">
  <h1 class="main-page__title">{{ page.title }}</h1>
  <div class="main-page__content rte">{{ page.content }}</div>
</article>

{% schema %}
{
  "name": "Page content",
  "tag": "section",
  "class": "section-page",
  "settings": []
}
{% endschema %}
