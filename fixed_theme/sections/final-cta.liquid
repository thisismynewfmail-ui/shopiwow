<section class="section">
  <div class="container">
    <div style="
      background: linear-gradient(135deg, var(--color-primary) 0%, #2a2520 100%);
      color: var(--color-primary-text);
      border-radius: calc(var(--card-radius) * 1.5);
      padding: clamp(40px, 8vw, 96px);
      text-align: center;
      position: relative;
      overflow: hidden;
    ">
      <div style="max-width: 760px; margin: 0 auto; position: relative; z-index: 1;">
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow eyebrow--gold">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="mt-sm" style="color: var(--color-primary-text);">{{ section.settings.heading }}</h2>
        {%- if section.settings.text != blank -%}
          <p style="color: var(--color-primary-text); opacity:.92; font-size:1.125rem;">{{ section.settings.text }}</p>
        {%- endif -%}
        <div class="flex justify-center gap-sm flex-wrap mt-md">
          <a href="{{ section.settings.primary_link | default: routes.all_products_collection_url }}" class="btn btn--secondary btn--lg">
            {{ section.settings.primary_label | default: 'Get started — $179 first month' }}
            {% render 'icon', icon: 'arrow-right' %}
          </a>
          {%- if section.settings.secondary_label != blank -%}
            <a href="{{ section.settings.secondary_link }}" class="btn btn--ghost btn--lg" style="color:var(--color-primary-text); border:2px solid rgba(255,255,255,.2);">
              {{ section.settings.secondary_label }}
            </a>
          {%- endif -%}
        </div>
        {%- if section.settings.micro_copy != blank -%}
          <p class="mt-md" style="color: var(--color-primary-text); opacity:.7; font-size:.9375rem;">{{ section.settings.micro_copy }}</p>
        {%- endif -%}
      </div>
      <div aria-hidden="true" style="
        position: absolute;
        inset: auto -10% -40% auto;
        width: 420px;
        height: 420px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(198,166,115,.25), transparent 70%);
      "></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Final CTA",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Your next chapter" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What's your weight loss goal?" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "See if you qualify in under 3 minutes. No contract, free shipping, unlimited support — and a doctor-led plan waiting for you." },
    { "type": "text", "id": "primary_label", "label": "Primary CTA label", "default": "Get started — $179 first month" },
    { "type": "url", "id": "primary_link", "label": "Primary CTA link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary CTA label", "default": "See how it works" },
    { "type": "url", "id": "secondary_link", "label": "Secondary CTA link" },
    { "type": "text", "id": "micro_copy", "label": "Micro-copy", "default": "FSA/HSA reimbursable · Free, fast shipping · Cancel any time" }
  ],
  "presets": [{ "name": "Final CTA", "category": "Call to action" }]
}
{% endschema %}
