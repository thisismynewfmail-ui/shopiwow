<section class="section">
  <div class="container">
    <div style="max-width: 820px; margin: 0 auto; text-align: {{ section.settings.align }};">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'eyebrow' -%}
            <span class="eyebrow" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
          {%- when 'heading' -%}
            <h2 class="mt-sm" {{ block.shopify_attributes }}>{{ block.settings.text }}</h2>
          {%- when 'text' -%}
            <div class="rte mt-md" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
          {%- when 'button' -%}
            <a href="{{ block.settings.link | default: '#' }}" class="btn btn--{{ block.settings.style }} btn--lg mt-md" {{ block.shopify_attributes }}>
              {{ block.settings.label }}
            </a>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Rich text",
  "settings": [
    {
      "type": "select",
      "id": "align",
      "label": "Alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "eyebrow",
      "name": "Eyebrow",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Metabolic science" }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "We will fix your broken metabolism." }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Traditional diets don't work because nearly 70% of weight is genetically determined. With medication, you work with your body rather than against it — to reach your goal weight, and keep it that way.</p>" }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Get started" },
        { "type": "url", "id": "link", "label": "Link" },
        {
          "type": "select",
          "id": "style",
          "label": "Style",
          "default": "primary",
          "options": [
            { "value": "primary", "label": "Primary" },
            { "value": "secondary", "label": "Secondary" },
            { "value": "outline", "label": "Outline" }
          ]
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Rich text",
      "category": "Content",
      "blocks": [
        { "type": "eyebrow" },
        { "type": "heading" },
        { "type": "text" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}
