{%- style -%}
  .main-list-collections { padding: 4rem 0 5rem; }
  .main-list-collections__header { text-align: center; margin-bottom: 2.5rem; }
  .main-list-collections__title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
  }
  .main-list-collections__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .collection-card {
    display: block;
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.05);
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease;
  }
  .collection-card:hover { transform: translateY(-3px); }
  .collection-card img { width: 100%; aspect-ratio: 3/2; object-fit: cover; }
  .collection-card__body { padding: 1rem 1.25rem; }
  .collection-card__title { font-size: 1.1rem; font-weight: 700; color: var(--color-primary); margin: 0; }
{%- endstyle -%}

<section class="main-list-collections">
  <div class="container">
    <div class="main-list-collections__header">
      <h1 class="main-list-collections__title">{{ page_title }}</h1>
    </div>
    <div class="main-list-collections__grid">
      {%- for collection in collections -%}
        <a class="collection-card" href="{{ collection.url }}">
          {%- if collection.featured_image != blank -%}
            <img src="{{ collection.featured_image | image_url: width: 600 }}" alt="{{ collection.title | escape }}" loading="lazy">
          {%- endif -%}
          <div class="collection-card__body">
            <h2 class="collection-card__title">{{ collection.title }}</h2>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collections list",
  "tag": "section",
  "class": "section-main-list-collections",
  "settings": []
}
{% endschema %}
