{%- style -%}
  .main-404 {
    padding: 6rem 2rem;
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }
  .main-404__title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }
  .main-404__text {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }
  .main-404__link {
    display: inline-block;
    padding: 1rem 2rem;
    background: var(--color-accent);
    color: #fff;
    text-decoration: none;
    border-radius: 10px;
    font-weight: 700;
    transition: all 0.25s ease;
  }
  .main-404__link:hover {
    background: var(--color-accent-hover);
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(8,168,138,0.3);
  }
{%- endstyle -%}

<section class="main-404">
  <h1 class="main-404__title">{{ 'general.404.title' | t }}</h1>
  <p class="main-404__text">{{ 'general.404.subtext' | t }}</p>
  <a class="main-404__link" href="{{ routes.root_url }}">&larr; {{ 'general.404.link' | t }}</a>
</section>

{% schema %}
{
  "name": "404",
  "tag": "section",
  "class": "section-main-404",
  "settings": []
}
{% endschema %}
