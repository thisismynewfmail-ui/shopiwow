{%- style -%}
  .medvi-products {
    padding: 5rem 0;
    background: #fff;
  }
  .medvi-products__header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 3rem;
  }
  .medvi-products__title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }
  .medvi-products__title em {
    color: var(--color-accent);
    font-style: normal;
  }
  .medvi-products__subtitle {
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }
  .medvi-products__subtitle strong { color: var(--color-accent); font-weight: 600; }

  .medvi-products__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.25rem;
  }

  .medvi-products__card {
    position: relative;
    padding: 2rem 1.25rem 1.5rem;
    border-radius: 16px;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 380px;
    color: var(--color-primary);
  }

  .medvi-products__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.1);
  }

  .medvi-products__card--mint { background: #e8f5f3; }
  .medvi-products__card--sand { background: #eee6e0; }
  .medvi-products__card--sky  { background: #dceaf4; }

  .medvi-products__tag {
    position: absolute;
    top: 1rem;
    left: 1rem;
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .medvi-products__tag--popular { background: var(--color-accent); color: #fff; }
  .medvi-products__tag--rx { background: var(--color-primary); color: #fff; }

  .medvi-products__image {
    text-align: center;
    margin: 1rem 0 1.5rem;
    min-height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .medvi-products__image img { max-width: 180px; max-height: 160px; height: auto; }

  .medvi-products__info { text-align: center; }

  .medvi-products__price {
    font-size: 1.05rem;
    font-weight: 800;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }
  .medvi-products__price--muted { color: var(--color-text-muted); }

  .medvi-products__name {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--color-primary);
  }

  .medvi-products__desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    min-height: 2.6em;
  }

  .medvi-products__btn {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    padding: 0.7rem 1.25rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.9rem;
    transition: background 0.25s ease;
  }
  .medvi-products__card:hover .medvi-products__btn { background: var(--color-accent-hover); }

  @media (max-width: 1100px) {
    .medvi-products__grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 768px) {
    .medvi-products__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .medvi-products__grid { grid-template-columns: 1fr; }
  }
{%- endstyle -%}

<section class="medvi-products" id="products">
  <div class="container">
    <div class="medvi-products__header">
      <h2 class="medvi-products__title">
        {{ section.settings.title | default: 'Trusted by experts,' }} <em>{{ section.settings.title_highlight | default: 'priced for you.' }}</em>
      </h2>
      <p class="medvi-products__subtitle">
        {{ section.settings.subtitle | default: 'Find the right GLP-1 medication with the confidence that comes from knowing it is <strong>doctor-approved</strong> and budget-friendly.' }}
      </p>
    </div>

    <div class="medvi-products__grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '/pages/intake-form' }}" class="medvi-products__card medvi-products__card--{{ block.settings.bg_theme | default: 'mint' }}" {{ block.shopify_attributes }}>
          {%- if block.settings.tag != blank -%}
            <span class="medvi-products__tag medvi-products__tag--{{ block.settings.tag_style | default: 'rx' }}">{{ block.settings.tag }}</span>
          {%- endif -%}
          <div class="medvi-products__image">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.name | escape }}" loading="lazy">
            {%- else -%}
              <img src="{{ block.settings.fallback_asset | default: 'glp-injections-n.png' | asset_url }}" alt="{{ block.settings.name | escape }}" loading="lazy">
            {%- endif -%}
          </div>
          <div class="medvi-products__info">
            <div class="medvi-products__price {% if block.settings.price_muted %}medvi-products__price--muted{% endif %}">{{ block.settings.price }}</div>
            <div class="medvi-products__name">{{ block.settings.name }}</div>
            <div class="medvi-products__desc">{{ block.settings.description }}</div>
            <span class="medvi-products__btn">{{ block.settings.cta_text | default: 'Get Started' }} &rarr;</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Products",
  "tag": "section",
  "class": "section-products",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Trusted by experts," },
    { "type": "text", "id": "title_highlight", "label": "Title highlight", "default": "priced for you." },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Find the right GLP-1 medication with the confidence that comes from knowing it is doctor-approved and budget-friendly." }
  ],
  "max_blocks": 8,
  "blocks": [
    {
      "type": "product_card",
      "name": "Product",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Product name" },
        { "type": "text", "id": "price", "label": "Price label", "default": "Starting at $179" },
        { "type": "checkbox", "id": "price_muted", "label": "Price in muted color", "default": false },
        { "type": "text", "id": "description", "label": "Description", "default": "Short description." },
        { "type": "text", "id": "tag", "label": "Tag", "default": "Rx" },
        { "type": "select", "id": "tag_style", "label": "Tag style",
          "options": [
            { "value": "popular", "label": "Popular (teal)" },
            { "value": "rx", "label": "Rx (navy)" }
          ],
          "default": "rx"
        },
        { "type": "select", "id": "bg_theme", "label": "Card color",
          "options": [
            { "value": "mint", "label": "Mint" },
            { "value": "sand", "label": "Sand" },
            { "value": "sky", "label": "Sky" }
          ],
          "default": "mint"
        },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "fallback_asset", "label": "Fallback asset filename", "default": "glp-injections-n.png" },
        { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Get Started" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "product_card", "settings": { "name": "GLP-1 Injections", "price": "Starting at $179", "description": "One simple injection per week.", "tag": "Popular", "tag_style": "popular", "bg_theme": "mint", "fallback_asset": "glp-injections-n.png" } },
      { "type": "product_card", "settings": { "name": "Wegovy® Pill", "price": "$99 Membership + Medication", "description": "One pill per day.", "tag": "Rx", "tag_style": "rx", "bg_theme": "sand", "fallback_asset": "wegovypill2.webp" } },
      { "type": "product_card", "settings": { "name": "GLP-1 Tablets", "price": "Starting at $249", "description": "One dissolvable tablet per day.", "tag": "Rx", "tag_style": "rx", "bg_theme": "mint", "fallback_asset": "glp-tablets-n.png" } },
      { "type": "product_card", "settings": { "name": "Wegovy® Injection", "price": "$99 Membership + Medication", "price_muted": true, "description": "Availability is subject to change.", "tag": "Rx", "tag_style": "rx", "bg_theme": "sky", "fallback_asset": "wegovypen.png" } },
      { "type": "product_card", "settings": { "name": "Zepbound® Injection", "price": "$99 Membership + Medication", "price_muted": true, "description": "Availability is subject to change.", "tag": "Rx", "tag_style": "rx", "bg_theme": "sky", "fallback_asset": "zepboundpen.png" } }
    ]
  },
  "presets": [
    {
      "name": "Products",
      "blocks": [
        { "type": "product_card", "settings": { "name": "GLP-1 Injections", "price": "Starting at $179", "description": "One simple injection per week.", "tag": "Popular", "tag_style": "popular", "bg_theme": "mint", "fallback_asset": "glp-injections-n.png" } },
        { "type": "product_card", "settings": { "name": "Wegovy® Pill", "price": "$99 Membership + Medication", "description": "One pill per day.", "tag": "Rx", "tag_style": "rx", "bg_theme": "sand", "fallback_asset": "wegovypill2.webp" } },
        { "type": "product_card", "settings": { "name": "GLP-1 Tablets", "price": "Starting at $249", "description": "One dissolvable tablet per day.", "tag": "Rx", "tag_style": "rx", "bg_theme": "mint", "fallback_asset": "glp-tablets-n.png" } },
        { "type": "product_card", "settings": { "name": "Wegovy® Injection", "price": "$99 Membership + Medication", "price_muted": true, "description": "Availability is subject to change.", "tag": "Rx", "tag_style": "rx", "bg_theme": "sky", "fallback_asset": "wegovypen.png" } },
        { "type": "product_card", "settings": { "name": "Zepbound® Injection", "price": "$99 Membership + Medication", "price_muted": true, "description": "Availability is subject to change.", "tag": "Rx", "tag_style": "rx", "bg_theme": "sky", "fallback_asset": "zepboundpen.png" } }
      ]
    }
  ]
}
{% endschema %}
