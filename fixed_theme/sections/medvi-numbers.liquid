{%- style -%}
  .medvi-numbers {
    padding: 5rem 0;
    background: #fff;
  }
  .medvi-numbers__header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 3rem;
  }
  .medvi-numbers__title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }
  .medvi-numbers__title em { color: var(--color-accent); font-style: normal; }
  .medvi-numbers__sub { color: var(--color-text-muted); font-size: 1.05rem; }

  .medvi-numbers__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .medvi-numbers__card {
    text-align: center;
    padding: 2rem 1.25rem;
    border-radius: 16px;
    background: var(--color-background-alt);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    border: 1px solid transparent;
  }
  .medvi-numbers__card:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.08);
    border-color: rgba(8,168,138,0.2);
  }

  .medvi-numbers__value {
    font-size: 2.75rem;
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    font-feature-settings: "tnum";
  }
  .medvi-numbers__value em { color: var(--color-accent); font-style: normal; }
  .medvi-numbers__value .unit { font-size: 1.5rem; vertical-align: super; margin-left: 2px; }

  .medvi-numbers__label {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .medvi-numbers__grid { grid-template-columns: repeat(2, 1fr); }
  }
{%- endstyle -%}

<section class="medvi-numbers" id="the-numbers">
  <div class="container">
    <div class="medvi-numbers__header">
      <h2 class="medvi-numbers__title">
        {{ section.settings.title | default: "Why are so many patients signing up for MEDVi?" }} <em>{{ section.settings.title_highlight | default: 'It works.' }}</em>
      </h2>
      <p class="medvi-numbers__sub">
        {{ section.settings.subtitle | default: 'On average, patients in the MEDVi program lose 15-20% of their body weight.' }}
      </p>
    </div>

    <div class="medvi-numbers__grid">
      {%- for block in section.blocks -%}
        <div class="medvi-numbers__card" {{ block.shopify_attributes }}>
          <div class="medvi-numbers__value">
            <em>{{ block.settings.value }}</em>{%- if block.settings.unit != blank -%}<span class="unit">{{ block.settings.unit }}</span>{%- endif -%}
          </div>
          <div class="medvi-numbers__label">{{ block.settings.label }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Numbers",
  "tag": "section",
  "class": "section-numbers",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Why are so many patients signing up for MEDVi?" },
    { "type": "text", "id": "title_highlight", "label": "Title highlight", "default": "It works." },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "On average, patients in the MEDVi program lose 15-20% of their body weight." }
  ],
  "max_blocks": 8,
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "default": "18" },
        { "type": "text", "id": "unit", "label": "Unit", "default": "%" },
        { "type": "text", "id": "label", "label": "Label", "default": "Average weight loss" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "stat", "settings": { "value": "18", "unit": "%", "label": "Average weight loss" } },
      { "type": "stat", "settings": { "value": "9/10", "unit": "", "label": "Patients call it the most effective treatment to date" } },
      { "type": "stat", "settings": { "value": "5.7", "unit": "\"", "label": "Potential waist reduction" } },
      { "type": "stat", "settings": { "value": "93", "unit": "%", "label": "Kept the weight off" } }
    ]
  },
  "presets": [
    {
      "name": "Numbers",
      "blocks": [
        { "type": "stat", "settings": { "value": "18", "unit": "%", "label": "Average weight loss" } },
        { "type": "stat", "settings": { "value": "9/10", "unit": "", "label": "Patients call it the most effective treatment to date" } },
        { "type": "stat", "settings": { "value": "5.7", "unit": "\"", "label": "Potential waist reduction" } },
        { "type": "stat", "settings": { "value": "93", "unit": "%", "label": "Kept the weight off" } }
      ]
    }
  ]
}
{% endschema %}
