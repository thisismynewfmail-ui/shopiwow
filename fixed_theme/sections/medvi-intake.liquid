{%- style -%}
  .medvi-intake {
    padding: 4rem 0 5rem;
    background: var(--color-background-alt);
    min-height: 70vh;
  }
  .medvi-intake__container {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .medvi-intake__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .medvi-intake__eyebrow {
    display: inline-block;
    background: rgba(8,168,138,0.12);
    color: var(--color-accent);
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .medvi-intake__title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    margin-bottom: 0.75rem;
  }
  .medvi-intake__title em { color: var(--color-accent); font-style: normal; }
  .medvi-intake__sub {
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }

  .medvi-intake__progress {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-bottom: 2rem;
  }
  .medvi-intake__progress span {
    width: 40px;
    height: 4px;
    border-radius: 4px;
    background: #d5cfcc;
    transition: background 0.3s ease;
  }
  .medvi-intake__progress span.active { background: var(--color-accent); }

  .medvi-intake__form {
    background: #fff;
    padding: 2rem;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.06);
  }
  .medvi-intake__step {
    display: none;
    animation: medvi-fadein 0.35s ease;
  }
  .medvi-intake__step.active { display: block; }
  @keyframes medvi-fadein { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }

  .medvi-intake__step h2 {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--color-primary);
  }

  .medvi-intake__options {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .medvi-intake__option {
    display: block;
    padding: 1rem 1.25rem;
    border: 2px solid #e4dcd8;
    border-radius: 12px;
    cursor: pointer;
    font-weight: 600;
    background: #fff;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .medvi-intake__option:hover { border-color: var(--color-accent); background: #f6fbfa; }
  .medvi-intake__option input { margin-right: 0.5rem; accent-color: var(--color-accent); }
  .medvi-intake__option input:checked + span { color: var(--color-accent); }

  .medvi-intake__field { margin-bottom: 1.25rem; }
  .medvi-intake__field label {
    display: block;
    font-weight: 600;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-primary);
  }
  .medvi-intake__field input,
  .medvi-intake__field select,
  .medvi-intake__field textarea {
    width: 100%;
    padding: 0.875rem 1rem;
    border: 2px solid #e4dcd8;
    border-radius: 10px;
    font-size: 1rem;
    font-family: inherit;
    background: #fff;
    transition: border-color 0.2s ease;
  }
  .medvi-intake__field input:focus,
  .medvi-intake__field select:focus,
  .medvi-intake__field textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 4px rgba(8,168,138,0.12);
  }
  .medvi-intake__field textarea { min-height: 100px; resize: vertical; }

  .medvi-intake__controls {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1.5rem;
  }
  .medvi-intake__btn {
    padding: 0.9rem 1.75rem;
    border-radius: 10px;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    border: none;
    transition: all 0.25s ease;
  }
  .medvi-intake__btn--next {
    background: var(--color-accent);
    color: #fff;
    margin-left: auto;
  }
  .medvi-intake__btn--next:hover { background: var(--color-accent-hover); transform: translateY(-1px); }
  .medvi-intake__btn--back {
    background: #f1ebe7;
    color: var(--color-primary);
  }
  .medvi-intake__btn--back:hover { background: #e4dcd8; }

  .medvi-intake__trust {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 2rem;
    flex-wrap: wrap;
    color: var(--color-text-muted);
    font-size: 0.88rem;
  }
  .medvi-intake__trust-item {
    display: flex; align-items: center; gap: 0.5rem;
  }
  .medvi-intake__trust-item img { width: 20px; height: 20px; }
{%- endstyle -%}

<section class="medvi-intake">
  <div class="medvi-intake__container">
    <div class="medvi-intake__header">
      <span class="medvi-intake__eyebrow">Takes 2 minutes · 100% confidential</span>
      <h1 class="medvi-intake__title">
        {{ section.settings.title | default: 'Get started with' }} <em>MEDVi</em>
      </h1>
      <p class="medvi-intake__sub">{{ section.settings.subtitle | default: "Answer a few quick questions to see if you qualify for GLP-1 medication — reviewed by a licensed provider." }}</p>
    </div>

    <div class="medvi-intake__progress" data-intake-progress>
      <span class="active"></span><span></span><span></span><span></span>
    </div>

    <form class="medvi-intake__form" data-intake-form onsubmit="return false;">
      <div class="medvi-intake__step active" data-step="1">
        <h2>What's your weight loss goal?</h2>
        <div class="medvi-intake__options">
          <label class="medvi-intake__option"><input type="radio" name="goal" value="1-20"> <span>Lose 1–20 lbs</span></label>
          <label class="medvi-intake__option"><input type="radio" name="goal" value="21-50"> <span>Lose 21–50 lbs</span></label>
          <label class="medvi-intake__option"><input type="radio" name="goal" value="51+"> <span>Lose 51+ lbs</span></label>
          <label class="medvi-intake__option"><input type="radio" name="goal" value="unsure"> <span>Not sure, I just want to lose the weight</span></label>
        </div>
        <div class="medvi-intake__controls">
          <button type="button" class="medvi-intake__btn medvi-intake__btn--next" data-next>Continue &rarr;</button>
        </div>
      </div>

      <div class="medvi-intake__step" data-step="2">
        <h2>Tell us about yourself</h2>
        <div class="medvi-intake__field"><label for="intake_name">Full name</label><input type="text" id="intake_name" name="name" required></div>
        <div class="medvi-intake__field"><label for="intake_email">Email</label><input type="email" id="intake_email" name="email" required></div>
        <div class="medvi-intake__field"><label for="intake_phone">Phone</label><input type="tel" id="intake_phone" name="phone" required></div>
        <div class="medvi-intake__controls">
          <button type="button" class="medvi-intake__btn medvi-intake__btn--back" data-back>&larr; Back</button>
          <button type="button" class="medvi-intake__btn medvi-intake__btn--next" data-next>Continue &rarr;</button>
        </div>
      </div>

      <div class="medvi-intake__step" data-step="3">
        <h2>Your health profile</h2>
        <div class="medvi-intake__field"><label for="intake_age">Age</label><input type="number" id="intake_age" name="age" min="18" max="100" required></div>
        <div class="medvi-intake__field"><label for="intake_weight">Current weight (lbs)</label><input type="number" id="intake_weight" name="weight" min="80" max="500" required></div>
        <div class="medvi-intake__field"><label for="intake_height">Height (inches)</label><input type="number" id="intake_height" name="height" min="48" max="96" required></div>
        <div class="medvi-intake__controls">
          <button type="button" class="medvi-intake__btn medvi-intake__btn--back" data-back>&larr; Back</button>
          <button type="button" class="medvi-intake__btn medvi-intake__btn--next" data-next>Continue &rarr;</button>
        </div>
      </div>

      <div class="medvi-intake__step" data-step="4">
        <h2>Medical background</h2>
        <div class="medvi-intake__field">
          <label for="intake_conditions">Any of these conditions?</label>
          <select id="intake_conditions" name="conditions">
            <option value="">Select a condition</option>
            <option value="diabetes">Type 2 Diabetes</option>
            <option value="heart-disease">Heart Disease</option>
            <option value="high-bp">High Blood Pressure</option>
            <option value="thyroid">Thyroid Condition</option>
            <option value="none">None of the above</option>
          </select>
        </div>
        <div class="medvi-intake__field">
          <label for="intake_medications">Current medications</label>
          <textarea id="intake_medications" name="medications" placeholder="List any medications (or type None)"></textarea>
        </div>
        <div class="medvi-intake__controls">
          <button type="button" class="medvi-intake__btn medvi-intake__btn--back" data-back>&larr; Back</button>
          <button type="submit" class="medvi-intake__btn medvi-intake__btn--next">Submit &amp; get approved &rarr;</button>
        </div>
      </div>
    </form>

    <div class="medvi-intake__trust">
      <div class="medvi-intake__trust-item"><img src="{{ 'icn-doctor.svg' | asset_url }}" alt=""><span>Licensed medical providers</span></div>
      <div class="medvi-intake__trust-item"><img src="{{ 'icn-guarantee.svg' | asset_url }}" alt=""><span>MEDVi guarantee</span></div>
      <div class="medvi-intake__trust-item"><img src="{{ 'icn-shipping.svg' | asset_url }}" alt=""><span>Free shipping</span></div>
    </div>
  </div>
</section>

<script>
  (function() {
    var form = document.querySelector('[data-intake-form]');
    if (!form) return;
    var steps = form.querySelectorAll('.medvi-intake__step');
    var dots = document.querySelectorAll('[data-intake-progress] span');
    var current = 0;
    function show(i) {
      steps.forEach(function (s, idx) { s.classList.toggle('active', idx === i); });
      dots.forEach(function (d, idx) { d.classList.toggle('active', idx <= i); });
      current = i;
      window.scrollTo({ top: form.offsetTop - 80, behavior: 'smooth' });
    }
    form.addEventListener('click', function (e) {
      if (e.target.matches('[data-next]')) {
        if (current < steps.length - 1) show(current + 1);
      } else if (e.target.matches('[data-back]')) {
        if (current > 0) show(current - 1);
      }
    });
    form.addEventListener('submit', function () {
      form.innerHTML = '<div class="medvi-intake__step active" style="text-align:center;padding:2rem 0;"><h2 style="color:var(--color-accent);font-size:1.75rem;">You\'re all set!</h2><p style="color:var(--color-text-muted);margin-top:1rem;">A licensed provider will review your information and reach out shortly. Welcome to MEDVi.</p></div>';
    });
  })();
</script>

{% schema %}
{
  "name": "Intake Form",
  "tag": "section",
  "class": "section-intake",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "Get started with" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Answer a few quick questions to see if you qualify for GLP-1 medication — reviewed by a licensed provider." }
  ],
  "presets": [ { "name": "Intake Form" } ]
}
{% endschema %}
