{%- style -%}
  .medvi-metabolism {
    padding: 5rem 0;
    background: linear-gradient(180deg, #fff 0%, var(--color-background-alt) 100%);
  }
  .medvi-metabolism__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .medvi-metabolism__media {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .medvi-metabolism__media img {
    width: 100%;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
  }
  .medvi-metabolism__media img:first-child { margin-top: 2rem; }
  .medvi-metabolism__title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }
  .medvi-metabolism__title em { color: var(--color-accent); font-style: normal; }
  .medvi-metabolism__text {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 1rem;
    font-size: 1.02rem;
  }
  .medvi-metabolism__text strong { color: var(--color-primary); font-weight: 700; }
  .medvi-metabolism__cta {
    display: inline-block;
    margin-top: 1rem;
    background: var(--color-accent);
    color: #fff;
    padding: 0.9rem 1.75rem;
    border-radius: 10px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.25s ease;
  }
  .medvi-metabolism__cta:hover {
    background: var(--color-accent-hover);
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(8,168,138,0.3);
  }
  @media (max-width: 900px) {
    .medvi-metabolism__layout { grid-template-columns: 1fr; }
    .medvi-metabolism__media img:first-child { margin-top: 0; }
  }
{%- endstyle -%}

<section class="medvi-metabolism" id="metabolism">
  <div class="container">
    <div class="medvi-metabolism__layout">
      <div class="medvi-metabolism__media">
        <img src="{{ 'metabolism-grid-1.jpg' | asset_url }}" alt="Patient receiving GLP-1 treatment" loading="lazy">
        <img src="{{ 'metabolism-grid-2.jpg' | asset_url }}" alt="Healthy lifestyle" loading="lazy">
      </div>
      <div class="medvi-metabolism__body">
        <h2 class="medvi-metabolism__title">
          {{ section.settings.title | default: "We'll fix your" }} <em>{{ section.settings.title_highlight | default: 'broken metabolism.' }}</em>
        </h2>
        <p class="medvi-metabolism__text">
          {{ section.settings.paragraph1 | default: "Want to reach your goal weight fast? It's not magic — it's metabolic science. GLP-1 is a naturally occurring hormone that regulates appetite and blood sugar, <strong>improving your metabolism and knocking out cravings</strong>." }}
        </p>
        <p class="medvi-metabolism__text">
          {{ section.settings.paragraph2 | default: "Traditional diets don't work because nearly <strong>70% of weight is genetically determined</strong>. With MEDVi's prescribed GLP-1 medication, you'll finally work with your body rather than against it — to reach your goal weight and keep it that way." }}
        </p>
        <a href="{{ section.settings.cta_link | default: '/pages/intake-form' }}" class="medvi-metabolism__cta">
          {{ section.settings.cta_text | default: 'See if I qualify' }} &rarr;
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Metabolism",
  "tag": "section",
  "class": "section-metabolism",
  "settings": [
    { "type": "text", "id": "title", "label": "Title", "default": "We'll fix your" },
    { "type": "text", "id": "title_highlight", "label": "Title highlight", "default": "broken metabolism." },
    { "type": "richtext", "id": "paragraph1", "label": "Paragraph 1" },
    { "type": "richtext", "id": "paragraph2", "label": "Paragraph 2" },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "See if I qualify" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "presets": [ { "name": "Metabolism" } ]
}
{% endschema %}
